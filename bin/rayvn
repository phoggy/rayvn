parseDocsUpdateArgs() {
    _opts+=(['delay']="5")
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=docsUpdateCmdUsage
    local _value
    while (( $# > 0 )); do
        case "$1" in
            --delay) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--stale-only|--regen|-h|--since|--dry-run|--missing-only|--help|--lib|--delay)$ ) ]] && fail "missing value for --delay"; assertPositiveInt "$2"; _opts+=(['delay']="$2"); shift 2 ;;
            --delay=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --delay"; assertPositiveInt "${_value}"; _opts+=(['delay']="${_value}"); shift ;;
            --dry-run) _opts+=(['dry-run']="1"); shift ;;
            --dry-run=*) fail "--dry-run does not accept a value" ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --lib) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--stale-only|--regen|-h|--since|--dry-run|--missing-only|--help|--lib|--delay)$ ) ]] && fail "missing value for --lib"; _opts+=(['lib']="$2"); shift 2 ;;
            --lib=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --lib"; _opts+=(['lib']="${_value}"); shift ;;
            --missing-only) _opts+=(['missing-only']="1"); shift ;;
            --missing-only=*) fail "--missing-only does not accept a value" ;;
            --regen) _opts+=(['regen']="1"); shift ;;
            --regen=*) fail "--regen does not accept a value" ;;
            --since) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--stale-only|--regen|-h|--since|--dry-run|--missing-only|--help|--lib|--delay)$ ) ]] && fail "missing value for --since"; _opts+=(['since']="$2"); shift 2 ;;
            --since=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --since"; _opts+=(['since']="${_value}"); shift ;;
            --stale-only) _opts+=(['stale-only']="1"); shift ;;
            --stale-only=*) fail "--stale-only does not accept a value" ;;
            --) shift; _args+=("$@"); break ;;
            *) _args+=("$1"); shift ;;
        esac
    done
    declare -g _failHandler="${_prevFailHandler}"
}

