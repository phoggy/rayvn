parseIndexArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=indexCmdUsage
    local _value
    while (( $# > 0 )); do
        case "$1" in
            --compact | -c) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--output|--hash-file|--compact|-c|-o|-h|--no-compact|--help|--no-hash)$ ) ]] && fail "missing value for --compact"; _opts+=(['compact']="$2"); shift 2 ;;
            --compact=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --compact"; _opts+=(['compact']="${_value}"); shift ;;
            --hash-file) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--output|--hash-file|--compact|-c|-o|-h|--no-compact|--help|--no-hash)$ ) ]] && fail "missing value for --hash-file"; _opts+=(['hash-file']="$2"); shift 2 ;;
            --hash-file=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --hash-file"; _opts+=(['hash-file']="${_value}"); shift ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --no-compact) _opts+=(['no-compact']="1"); shift ;;
            --no-compact=*) fail "--no-compact does not accept a value" ;;
            --no-hash) _opts+=(['no-hash']="1"); shift ;;
            --no-hash=*) fail "--no-hash does not accept a value" ;;
            --output | -o) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--output|--hash-file|--compact|-c|-o|-h|--no-compact|--help|--no-hash)$ ) ]] && fail "missing value for --output"; _opts+=(['output']="$2"); shift 2 ;;
            --output=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --output"; _opts+=(['output']="${_value}"); shift ;;
            --) shift; _args+=("$@"); break ;;
            *) _args+=("$1"); shift ;;
        esac
    done
    declare -g _failHandler="${_prevFailHandler}"
}

