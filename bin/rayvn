    echo
    show bold "Create a new project, library, script or test from a template."
    echo
    show "Usage:" bold blue "rayvn new" "TYPE NAME [--local]"
    echo
    option "TYPE" "What to create: a project, script, library or test." 16
    option "NAME" "The name to create." 16
    option "--local" "Skip GitHub repo creation; initialize a local git repo only." 16
    option "--help, -h" "Print this help message." 16
    declare -F newCmdUsageExtra > /dev/null && newCmdUsageExtra
    bye "$@"
}

parsePagesArgs() {
    declare -g _optListRecord=()
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=pagesCmdUsage
    local _argIndex=0 _value _mutex
    while (( $# > 0 )); do
        case "$1" in
            --dir) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(--record|--view|--publish|--dir|-h|--help|--setup)$ ) ]] && fail "missing value for --dir"; _opts+=(['dir']="$2"); shift 2 ;;
            --dir=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --dir"; _opts+=(['dir']="${_value}"); shift ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --publish) _opts+=(['publish']="1"); shift ;;
            --publish=*) fail "--publish does not accept a value" ;;
            --record) shift
                while (( $# > 0 )) && [[ "$1" != -* ]]; do
                    _optListRecord+=("$1"); shift
                done
                _opts+=(['record']="1") ;;
            --record=*) _value="${1#*=}"; [[ -n "${_value}" ]] || fail "missing value for --record"; _optListRecord+=("${_value}"); _opts+=(['record']="1"); shift ;;
            --setup) _opts+=(['setup']="1"); shift ;;
            --setup=*) fail "--setup does not accept a value" ;;
            --view) _opts+=(['view']="1"); shift ;;
            --view=*) fail "--view does not accept a value" ;;
            --) shift
                while (( $# > 0 )); do
                    (( _argIndex == 0 )) || unknownArg "$1"
                    _args+=("$1"); (( _argIndex++ )); shift
                done ;;
            *) (( _argIndex == 0 )) || unknownArg "$1"; _args+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    _mutex=0
    [[ -v _opts['setup'] ]] && (( _mutex++ ))
    [[ -v _opts['record'] ]] && (( _mutex++ ))
    [[ -v _opts['publish'] ]] && (( _mutex++ ))
    [[ -v _opts['view'] ]] && (( _mutex++ ))
    (( _opts['help'] || _mutex <= 1 )) || fail "at most one of --setup | --record | --publish | --view may be specified"
    declare -g _failHandler="${_prevFailHandler}"
}

pagesCmdUsage() {
    echo
    show bold "Generate and preview the project's gh-pages site."
    echo
    show "Usage:" bold blue "rayvn pages" "[PROJECT] [--setup | --record | --publish | --view] [--dir DIR]"
    echo
    option "PROJECT" "Project name (default: current directory's project); only one may be" 26
    option "" "specified." 26
    option "--dir DIR" "Output directory (default: project's configured worktree)." 26
    option "--record [RECORD...]" "Re-record asciinema casts; optionally filter by cast ID(s), all if" 26
    option "" "omitted." 26
    option "--setup" "First-time setup: create gh-pages branch, worktree, and workflow." 26
    option "--publish" "Generate pages, then commit and push to gh-pages." 26
    option "--view" "Generate pages, then serve locally with Jekyll." 26
    option "--help, -h" "Print this help message." 26
    echo
    echo "Record markup (in any .md file in the pages dir):"
    echo
    echo "  <!-- record id=\"NAME\" cmd=\"COMMAND\" [cmd=\"COMMAND\" ...]"
    echo "       [pre=\"CMD\"] [post=\"CMD\"] [prompt=\"PS1\"] -->"
    echo "  {% include asciinema.html id=\"NAME\" src=\"...\" %}"
    echo
    echo "  Each <!-- record --> comment must be paired with a matching"
    echo "  {% include asciinema.html %} tag."
    echo
    echo "  id=      Cast identifier (must match the include tag's id= attribute)."
    echo "  cmd=     Command to record. Repeatable; commands are recorded sequentially."
    echo "  pre=     Optional setup command run before recording (not captured)."
    echo "  post=    Optional cleanup command run after recording (not captured)."
    echo "  prompt=  Optional shell prompt string (PS1) shown during recording."
    declare -F pagesCmdUsageExtra > /dev/null && pagesCmdUsageExtra
    bye "$@"
}

parseProjectsArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=projectsCmdUsage
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --) shift; _args+=("$@"); break ;;
            *) _args+=("$1"); shift ;;
        esac
    done
    declare -g _failHandler="${_prevFailHandler}"
}

projectsCmdUsage() {
    echo
    show bold "Show info for one or more projects."
    echo
    show "Usage:" bold blue "rayvn projects" "[PROJECT...]"
    echo
    option "PROJECT..." "Project names (default: current project)." 16
    option "--help, -h" "Print this help message." 16
    declare -F projectsCmdUsageExtra > /dev/null && projectsCmdUsageExtra
    bye "$@"
}

parseRegisterArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=registerCmdUsage
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --) shift
                while (( $# > 0 )); do
                    (( _argIndex == 0 )) || unknownArg "$1"
                    _args+=("$1"); (( _argIndex++ )); shift
                done ;;
            *) (( _argIndex == 0 )) || unknownArg "$1"; _args+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _opts['help'] || _argIndex >= 1 )) || { local -a _missingArgs=("NAME"); _missingArgs=("${_missingArgs[@]:${_argIndex}}"); (( ${#_missingArgs[@]} == 1 )) && fail "missing required argument: ${_missingArgs[0]}" || fail "missing required arguments: ${_missingArgs[*]}"; }
    declare -g _failHandler="${_prevFailHandler}"
}

registerCmdUsage() {
    echo
    show bold "Stake a claim on a project name on rayvn central."
    echo
    show "Usage:" bold blue "rayvn register" "NAME"
    echo
    option "NAME" "The project name to register." 16
    option "--help, -h" "Print this help message." 16
    declare -F registerCmdUsageExtra > /dev/null && registerCmdUsageExtra
    bye "$@"
}

parseReleaseArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=releaseCmdUsage
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --) shift
                while (( $# > 0 )); do
                    (( _argIndex == 0 )) && assertVersion "$1" || unknownArg "$1"
                    _args+=("$1"); (( _argIndex++ )); shift
                done ;;
            *) (( _argIndex == 0 )) && assertVersion "$1" || unknownArg "$1"; _args+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _opts['help'] || _argIndex >= 1 )) || { local -a _missingArgs=("VERSION"); _missingArgs=("${_missingArgs[@]:${_argIndex}}"); (( ${#_missingArgs[@]} == 1 )) && fail "missing required argument: ${_missingArgs[0]}" || fail "missing required arguments: ${_missingArgs[*]}"; }
    declare -g _failHandler="${_prevFailHandler}"
}

releaseCmdUsage() {
    echo
    show bold "Create a versioned GitHub release for the current directory's project. The GitHub repository is"
    show bold "derived from the git 'origin' remote and confirmed before releasing."
    echo
    show "Usage:" bold blue "rayvn release" "VERSION"
    echo
    option "VERSION" "The version to release, e.g. '1.2.3'; must be greater than the current version." 16
    option "--help, -h" "Print this help message." 16
    declare -F releaseCmdUsageExtra > /dev/null && releaseCmdUsageExtra
    bye "$@"
}

parseTestArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=testCmdUsage
    while (( $# > 0 )); do
        case "$1" in
            --all) _opts+=(['all']="1"); shift ;;
            --all=*) fail "--all does not accept a value" ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --nix) _opts+=(['nix']="1"); shift ;;
            --nix=*) fail "--nix does not accept a value" ;;
            --) shift; _args+=("$@"); break ;;
            *) _args+=("$1"); shift ;;
        esac
    done
    declare -g _failHandler="${_prevFailHandler}"
}

testCmdUsage() {
    echo
    show bold "Run tests for one or more projects."
    echo
    show "Usage:" bold blue "rayvn test" "[ARGS...] [--all] [--nix]"
    echo
    option "ARGS..." "Project names and/or test name patterns; prefix a pattern with '-' to exclude it." 16
    option "--nix" "Run tests inside a nix develop shell." 16
    option "--all" "Run tests locally and then again inside nix." 16
    option "--help, -h" "Print this help message." 16
    declare -F testCmdUsageExtra > /dev/null && testCmdUsageExtra
    bye "$@"
}

parseThemeArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=themeCmdUsage
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --show) _opts+=(['show']="1"); shift ;;
            --show=*) fail "--show does not accept a value" ;;
            --) shift; (( $# == 0 )) || unknownArg "$1" ;;
            *) unknownArg "$1" ;;
        esac
    done
    declare -g _failHandler="${_prevFailHandler}"
}

themeCmdUsage() {
    echo
    show bold "Interactively select a color theme for rayvn output or show the current theme."
    echo
    show "Usage:" bold blue "rayvn theme" "[--show]"
    echo
    option "--show" "Show current theme." 16
    option "--help, -h" "Print this help message." 16
    declare -F themeCmdUsageExtra > /dev/null && themeCmdUsageExtra
    bye "$@"
}

