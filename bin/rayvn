#!/usr/bin/env rayvn-bash
# shellcheck disable=SC2155
# shellcheck disable=SC2120

usage() {
    echo
    show bold "Manage shared libraries and executables."
    echo
    show "Usage:" bold "rayvn" "COMMAND [PROJECT] [PROJECT...] <options>"
    echo
    echo "Commands"
    echo
    echo "    new TYPE NAME     Create a new project, script, library or test with the specified NAME."
    echo "    test              Run tests."
    echo "    theme             Select theme."
    echo "    libraries         List libraries."
    echo "    functions         List functions."
    echo "    lint              Scan source files for requirement violations."
    echo "    collisions        Check for namespace collisions within and across projects."
    echo "    dependencies      Scan source files and ensure dependency tracking is up to date."
    echo "    index             Generate function indexes for AI agent use."
    echo "    docs              Audit or update function documentation."
    echo "    pages             Generate and preview project gh-pages site."
    echo "    build             Run nix build."
    echo "    release           Create a new release."
    echo "    register          Stake a claim on a project name, if available."
    echo
    echo "Use COMMAND --help for any additional details. PROJECT defaults to the current directory's project"
    echo "if within one. 'test' falls back to rayvn if not in a project."
    echo
    echo "Options:"
    echo
    echo "    -h, --help        Print this help message."
    echo "    -v                Print the version."
    echo "    --version         Print the version with release date."
    echo
    echo "Debug Options:"
    echo
    echo "    --debug           Enable debug, write output to log file and show on exit."
    echo "    --debug-new       Enable debug, clear log file, write output to log file and show on exit."
    echo "    --debug-out       Enable debug, write output to the current terminal."
    echo "    --debug-tty TTY   Enable debug, write output to the specified TTY (e.g., /dev/ttys001)."
    echo "    --debug-tty .     Enable debug, write output to the TTY path read from the '~/.debug.tty' file."
    bye "$@"
}

main() {
    init "$@"
    local result=0
    ${command} "${args[@]}" || result=$?
    return ${result}
}

init() {
    declare -g command=
    declare -g projects=()
    declare -g args=()
    declare -g gitHubRepo
    declare -gAi flags=()

    # process arguments

    while (( $# )) && [[ -z ${command} ]]; do
        case "$1" in
            test) parseArgs true testCmd "${@:2}" ;;
            build) parseArgs true buildCmd "${@:2}" ;;
            theme) parseArgs false themeCmd "${@:2}" ;;
            new | create) parseArgs false newCmd "${@:2}" ;;
            projects) parseArgs true projectsCmd "${@:2}" ;;
            libraries) parseArgs true librariesCmd "${@:2}" ;;
            functions) parseArgs true functionsCmd "${@:2}" ;;
            register) parseArgs false registerCmd "${@:2}" ;;
            release) parseArgs true releaseCmd "${@:2}" ;;
            index) parseArgs true indexCmd "${@:2}" ;;
            pages) parseArgs true pagesCmd "${@:2}" ;;
            docs) parseArgs true docsCmd "${@:2}" ;;
            lint) parseArgs true lintCmd "${@:2}" ;;
            collisions) parseArgs true collisionsCmd "${@:2}" ;;
            deps|dependencies) parseArgs true dependenciesCmd "${@:2}" ;;
            -v) printVersion; exit 0 ;;
            --version) printVersion true; exit 0 ;;
            --debug*) setDebug "$@"; shift $? ;;
            -h | --help | help) command='usage' ;;
            -*) command='usage'; args=("Unknown option:" "$1") ;;
            *) command='usage'; [[ -n $1 ]] && args=("Unknown command:" "$1");;
        esac
        shift
    done

    [[ -n ${command} ]] || usage
}

SECTION="--+-+-----+-++(-++(---++++(---+( ARGUMENT PARSING )+---)++++---)++-)++-+------+-+--"

parseArgs() {
    local add="$1"
    command="$2"
    shift 2
    while (( $# > 0 )); do
        case "$1" in
            -h | --help) flags+=(['help']=1) ;;
            -q | --quiet) flags+=(['quiet']=1) ;;
            --assert) flags+=(['assert']=1) ;;
            --local) flags+=(['local']=1) ;;
            --nix) flags+=(['nix']=1) ;;
            --all) flags+=(['all']=1) ;;
            --fix) flags+=(['fix']=1) ;;
            --ask) flags+=(['ask']=1) ;;
            --debug*) setDebug "$@"; shift $? ;;
            --repo) shift; gitHubRepo="$1";;
            -*) args+=("$1") ;;
            *)  if [[ ${add} == true ]]; then
                addIfRayvnExecutable "$1" || args+=("$1")
            else
                args+=("$1")
            fi ;;
        esac
        shift
    done
    [[ ${add} == true ]] && (( ${#projects[@]} == 0 )) && detectCurrentProject
}

detectCurrentProject() {
    local dir="${PWD}"
    while [[ -n "${dir}" && "${dir}" != '/' ]]; do
        if [[ -f "${dir}/rayvn.pkg" ]]; then
            local projectName; projectName=${ gawk -F"'" '/^projectName=/{print $2; exit}' "${dir}/rayvn.pkg"; }
            if [[ -n "${projectName}" ]]; then
                if [[ "${projectName}" != rayvn ]]; then
                    _addRayvnProject "${projectName}" "${dir}"
                fi
                projects+=( "${projectName}" )
            fi
            return 0
        fi
        dir="${dir%/*}"
    done
    return 0
}

addIfRayvnExecutable() {
    [[ ${command} == 'newCmd' ]] && return 1
    local name="$1"
    local path root rayvnPkgFile
    path="${ type -P "${name}"; }"
    if [[ -n "${path}" ]]; then
        if [[ "${name}" == 'rayvn'  ]]; then
            projects+=( "${name}" )
            return 0
        else
            # Get root directory

            path="${ realpath "${path}"; }"
            path="${path%/}"  # normalize trailing slash
            path="${path%/*}" # strip last component
            root="${path%/*}" # and again to reach root

            # See if there is a rayvn.pkg file

            rayvnPkgFile="${root}/rayvn.pkg"
            [[ -f "${rayvnPkgFile}" ]] || rayvnPkgFile="${root}/share/${name}/rayvn.pkg"
            if [[ -f ${rayvnPkgFile} ]]; then
                _addRayvnProject "${name}" "${root}"
                projects+=( "${name}" )
                return 0
            fi
        fi
    fi
    return 1
}

assertSingleProject() {
    (( ${#projects[@]} > 1 )) && fail "only one project name is supported"
}

assertProjectsSpecified() {
    (( ${#projects[@]} > 0 )) && return 0
    local candidate="${args[0]}"
    if [[ -n "${candidate}" && "${candidate}" != -* ]]; then
        fail "Unknown project:" blue "${candidate}" "— is its bin directory in PATH?"
    else
        fail "A project name is required (e.g. rayvn, valt, wardn)"
    fi
}

SECTION="--+-+-----+-++(-++(---++++(---+( COMMANDS )+---)++++---)++-)++-+------+-+--"

printUsage() {
    usage
}


newCmd() {
    if (( flags['help'] )); then
        echo "rayvn new project|script|library|test NAME [--local]"
        echo
        echo "  Create a new project, script, library, or test file from a template."
        echo
        echo "  --local  Skip GitHub repo creation; initialize a local git repo only."
    else
        local type=${args[0]}
        local name=${args[1]}
        local command=
        [[ -n "${type}" ]] || bye "one of 'project', 'script' 'library' or 'test' required"
        case ${type} in
            project | script | library | test) ;;
            *) bye "unknown type: ${type}"
        esac
        [[ -n "${name}" ]] || bye "name required"
        local gitRoot=${ git rev-parse --show-toplevel 2>/dev/null; } || gitRoot=''
        local templateDir="${rayvnHome}/templates"
        args=("${args[@]:3}")

        case ${type} in
            project) newProject;;
            script) newScript ;;
            library) newLibrary ;;
            test) newTest ;;
        esac
    fi
}

themeCmd() {
    if (( flags['help'] )); then
        echo "rayvn theme"
        echo
        echo "  Interactively select a color theme for rayvn output."
    else
        require 'rayvn/theme'
        setTheme
    fi
}

projectsCmd() {
    if (( flags['help'] )); then
        echo "rayvn projects [PROJECT...]"
        echo
        echo "  Show info for one or more projects."
    else
        echo
        forEachProject printProject "${args[@]}"
    fi
}

librariesCmd() {
    if (( flags['help'] )); then
        echo "rayvn libraries [PROJECT...]"
        echo
        echo "  List all libraries for one or more projects."
    else
        forEachProject printLibraries "$1"
    fi
}

functionsCmd() {
    if (( flags['help'] )); then
        echo "rayvn functions [PROJECT/LIBRARY | PROJECT... [LIBRARY]] [--all]"
        echo
        echo "  List public functions for project libraries."
        echo
        echo "  --all  Also list private (_-prefixed) functions."
    else
        if [[ -n ${args[0]:-} && ${args[0]} == */* ]]; then
            local qualifiedLib="${args[0]}"
            args[0]="${qualifiedLib##*/}"
            listProjectLibraries "${qualifiedLib%%/*}"
        else
            forEachProject listProjectLibraries "$1"
        fi
    fi
}

testCmd() {
    if (( flags['help'] )); then
        echo "rayvn test [PROJECT...] [TEST-NAME...] [--nix] [--all]"
        echo
        echo "  Run tests for one or more projects."
        echo
        echo "  --nix  Run tests inside a nix develop shell."
        echo "  --all  Run tests locally and then again inside nix."
    else
        require 'rayvn/test-harness'
        executeTests
    fi
}

buildCmd() {
    if (( flags['help'] )); then
        echo "rayvn build [PROJECT...]"
        echo
        echo "  Run nix build for one or more projects."
    else
        require 'rayvn/test-harness'
        executeNixBuild
    fi
}

indexCmd() {
    if (( flags['help'] )); then
        echo "rayvn index [-o FILE] [-c FILE] [--no-compact] [--no-hash] [--hash-file FILE]"
        echo
        echo "  Generates verbose and compact function indexes used by AI agents (e.g. Claude Code)."
        echo "  Run after adding or modifying library functions to keep the indexes current."
    else
        require 'rayvn/index'
        runIndex "${args[@]}"
    fi
}

pagesCmd() {
    if (( flags['help'] )); then
        echo "rayvn pages [PROJECT] [--dir DIR] [--setup | --record [ID...] | --publish | --view]"
        echo
        echo "  PROJECT defaults to the current directory's project; only one may be specified."
        echo
        echo "  --setup          First-time setup: create gh-pages branch, worktree, and workflow."
        echo "  --record [ID...] Re-record asciinema casts. Optionally filter by cast ID(s)."
        echo "  --dir DIR        Output directory (default: project's configured worktree)."
        echo "  --publish        Generate pages, then commit and push to gh-pages."
        echo "  --view           Generate pages, then serve locally with Jekyll."
        echo
        echo "Record markup (in any .md file in the pages dir):"
        echo
        echo "  <!-- record id=\"NAME\" cmd=\"COMMAND\" [cmd=\"COMMAND\" ...] [pre=\"CMD\"] [post=\"CMD\"] [prompt=\"PS1\"] -->"
        echo "  {% include asciinema.html id=\"NAME\" src=\"...\" %}"
        echo
        echo "  Each <!-- record --> comment must be paired with a matching {% include asciinema.html %} tag."
        echo
        echo "  id=      Cast identifier (must match the include tag's id= attribute)."
        echo "  cmd=     Command to record. Repeatable; commands are recorded sequentially."
        echo "  pre=     Optional setup command run before recording (not captured)."
        echo "  post=    Optional cleanup command run after recording (not captured)."
        echo "  prompt=  Optional shell prompt string (PS1) shown during recording."
        echo
    else
        assertProjectsSpecified
        (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
        require 'rayvn/index'
        runPages "${projects[0]}" "${args[@]}"
    fi
}

lintCmd() {
    if (( flags['help'] )); then
        echo "rayvn lint [PROJECT...] [--fix] [--ask]"
        echo
        echo "  Scan project source files for violations of rayvn's bash requirements."
        echo
        echo "  --fix  Auto-fix all violations that can be corrected automatically."
        echo "  --ask  Interactively prompt whether to fix each file with violations."
        echo
        echo "  Note: old-style command substitution \$() is detected but not auto-fixed." # lint-ok
    else
        assertProjectsSpecified
        (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
        local fixMode=
        (( flags['fix'] )) && fixMode='--fix'
        (( flags['ask'] )) && fixMode='--ask'
        require 'rayvn/lint'
        runLint ${fixMode} "${projects[@]}"
    fi
}

collisionsCmd() {
    if (( flags['help'] )); then
        echo "rayvn collisions [PROJECT...]"
        echo
        echo "  Check for function and global variable name collisions across project libraries."
    else
        require 'rayvn/namespace'
        if (( ${#projects[@]} > 0 )); then
            checkNamespaces "${projects[@]}"
        else
            checkNamespaces
        fi
    fi
}

dependenciesCmd() {
    if (( flags['help'] )) || (( ${#projects[@]} == 0 )); then
        echo "rayvn dependencies [--fix] [PROJECT...]"
        echo
        echo "  Scan source files for external command dependencies and verify they are"
        echo "  declared in flake.nix runtimeDeps."
        echo
        echo "  --fix  Auto-replace 'awk' with 'gawk' and 'sed' with 'gsed' in source files."
    else
        require 'rayvn/index'
        local fixMode=; (( flags['fix'] )) && fixMode=fix
        local project result=0
        for project in "${projects[@]}"; do
            findDependencies "${project}" "${fixMode}" || result=1
        done
        return ${result}
    fi
}

docsCmd() {
    if (( flags['help'] )); then
        echo "rayvn docs audit | update [PROJECT...] [OPTIONS]"
        echo
        echo "  audit [OPTIONS]    Report missing/stale ◇ doc comments."
        echo
        echo "  --release          Exit 1 if any public functions are missing ◇ doc comments."
        echo
        echo "  update [OPTIONS]   Generate or fix ◇ doc comments via Claude API."
        echo
        echo "  --dry-run          Print proposed docs without writing any changes."
        echo "  --regen            Regenerate docs for all public functions, not just missing/stale."
        echo "  --missing-only     Only process functions missing a ◇ doc comment."
        echo "  --stale-only       Only process functions with potentially stale docs."
        echo "  --lib NAME         Limit to a single library by name."
        echo "  --since DURATION   Skip functions updated within this duration (e.g. '30m', '2h', '1d')."
        echo "  --delay SECS       Seconds to sleep between API calls to avoid rate limits (default: 5)."
    else
        require 'rayvn/function-docs'
        local subcommand="${args[0]}"
        local subArgs=("${args[@]:1}")
        case "${subcommand}" in
            audit)  auditDocs  "${subArgs[@]}" ;;
            update) updateDocs "${subArgs[@]}" ;;
            *) fail "unknown subcommand: ${subcommand:-<none>}. Use audit or update." ;;
        esac
    fi
}

releaseCmd() {
    if (( flags['help'] )); then
        echo "rayvn release [PROJECT | --repo 'my-account/my-repo'] VERSION"
        echo
        echo "  Create a versioned GitHub release for a project."
        echo
        echo "  --repo ACCOUNT/REPO  Specify the GitHub repository explicitly."
    else
        local version=
        if (( ${#projects[@]} )); then
            assertSingleProject
            version="${args[0]}"
        elif (( ${#args[@]} == 1 )); then
            projects=(rayvn)
            version="${args[0]}"
        else
            projects=("${args[0]}")
            version="${args[1]}"
        fi

        [[ -n ${version} ]] || fail "version required"

        local ghRepo="${gitHubRepo}"
        if [[ -z ${ghRepo} ]]; then
            local project="${projects[0]}"
            case "${project}" in
                rayvn) ghRepo='phoggy/rayvn' ;;
                valt) ghRepo='phoggy/valt' ;;
                wardn) ghRepo='phoggy/wardn' ;;
                *) fail "Please specify project using GitHub repo format: --repo 'my-account/my-repo'."
            esac
        fi

        require 'rayvn/release'
        release "${ghRepo}" "${version}"
    fi
}

registerCmd() {
    if (( flags['help'] )); then
        echo "rayvn register PROJECT [--remove]"
        echo
        echo "  Stake a claim on a project name on rayvn central."
        echo
        echo "  --remove  Release the registered name."
    else
        assertGitRepo
        require 'rayvn/central'
        local projectName=${args[0]}
        [[ -n ${projectName} ]] || fail "project name required"
        local projectUrl repoName
        projectUrl="${ git remote get-url origin; }" || fail
        projectUrl="${projectUrl%.git}"
        repoName=${ baseName ${projectUrl}; }
        [[ ${projectName} == "${repoName}" ]]
        registerProjectOnRayvnCentral "${projectName}" || fail
    fi
}


SECTION="--+-+-----+-++(-++(---++++(---+( IMPLEMENTATION )+---)++++---)++-)++-+------+-+--"


printProject() {
    local projectName="$1"
    local projectRoot="$2"
    local version; version="${ projectVersion "${projectName}" true; }"
    echo "${version} -> ${projectRoot}"
}

printLibraries() {
    local project="$1"
    echo
    show bold "project ${project}" nl
    forEachLibrary "${project}" printProjectLibrary
}

printProjectLibrary() {
    local project="$1"
    local library="$2"
    show primary "    ${project}/${library}"
}

listProjectLibraries() {
    local project="$1"
    forEachLibrary "${project}" listFunctions
}

listFunctions() {
    local project=$1
    local library="$2"
    local libraryFile="$3"
    local libraryName="${project}/${library}"
    [[ -n ${args[0]:-} && ${library} != "${args[0]}" ]] && return 0
    local functions=()
    local function
    local includePrivate=0
    (( flags['all'] )) && includePrivate=1

    getFunctions "${libraryFile}" functions

    echo
    show bold "${libraryName} functions"
    echo

    for function in "${functions[@]}"; do
        [[ ${function} != _* ]] && show primary "    ${function}"
    done
    if (( includePrivate )); then
        for function in "${functions[@]}"; do
            [[ ${function} == _* ]] && show italic red "    ${function}"
        done
    fi
}

getFunctions() {
    local sourcePath="$1"
    local -n arrayRef="$2"
    local _functions
    assertFile "${sourcePath}"
    _functions=${ bash --norc --noprofile -c "source '${sourcePath}' 2>/dev/null; compgen -A function;"; } || return 1
    _functions=(${ printf '%s\n' "${_functions[@]}" | sort; })
    arrayRef=("${_functions[@]}")
}

forEachProject() {              # TODO: this pattern is a pain. Replace with getProjects()
    local command="$1"
    local arguments=("${@:2}")
    local projectRoot
    for project in "${projects[@]}"; do
        projectRoot="${_rayvnProjects[${project}::project]}"
        "${command}" "${project}" "${projectRoot}" "${arguments}"
    done
}

forEachLibrary() {              # TODO: this pattern is a pain. Replace with getLibraries() with optional project filter.
    local project="$1"
    local command="$2"
    local arguments=("${@:3}")
    local libraryRoot="${_rayvnProjects[${project}::library]}"
    [[ -n ${libraryRoot} ]] || fail "no libraries found for '${project}' project"
    for file in "${libraryRoot}"/*.sh; do
        [[ -e ${file} ]] || fail "no libraries found for '${project}' at ${libraryRoot}"
        local fileName="${ basename "${file}"; }"
        local library="${fileName%.*}"
        "${command}" "${project}" "${library}" "${file}" "${arguments}"
    done
}

printVersion() {
    local verbose="${1:-}"
    projectVersion rayvn "${verbose}"
}

printLibrary() {
    local projectName="$1"
    local libraryName="$2"
    local libraryRoot="$3"
    echo "${projectName}/${libraryName} -> ${libraryRoot}"
}

newProject() {
    [[ "${name}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || fail "sorry, '${name}' is not a valid bash identifier"
    [[ -n ${gitRoot} ]] && fail "${PWD} is within an existing project/git repo"
    local projectName="${name}"
    local projectRoot="${PWD}/${projectName}"
    assertFileDoesNotExist "${projectRoot}"
    local binDir="${projectRoot}/bin"
    local libDir="${projectRoot}/lib"
    local packageTemplate="${templateDir}/package-template.sh"
    local scriptTemplate="${templateDir}/script-template.sh"
    local libraryTemplate="${templateDir}/library-template.sh"
    local readmeTemplate="${templateDir}/readme-template.md"
    local flakeTemplate="${templateDir}/flake-template.nix"
    local formulaTemplate="${templateDir}/formula-template.rb"

    echo
    show bold "Creating project '${projectName}' in" blue "'${PWD}'"
    echo

    declare -i createdRepo=0
    local choiceIndex formulaFile repoUrl

    if (( flags['local'] )); then
        # --local flag: skip GitHub, just create local git repo
        makeDir "${projectRoot}" > /dev/null
        cd "${projectRoot}" || fail
        git init --initial-branch=main || fail
    else
        require 'rayvn/prompt' 'rayvn/central'
        confirm "Create new GitHub repo for project '${projectName}'?" yes no choiceIndex || bye
        if (( choiceIndex == 0 )); then
            if ! gh auth status --active &> /dev/null; then
                confirm "Need to authenticate. Do you have a GitHub account?" y n choiceIndex || bye
                if (( choiceIndex == 0 )); then
                    gh auth login || exit
                else
                    bye "Please go to https://github.com/ and create an account first."
                fi
            fi
            echo
            gh repo create "${projectName}" --add-readme --private --clone || fail
            cd "${projectRoot}" || fail
            repoUrl="${ git remote get-url origin; }"
            registerProjectOnRayvnCentral "${projectName}" || fail
            createdRepo=1
        else
            echo
            makeDir "${projectRoot}" > /dev/null
            cd "${projectRoot}" || fail
            git init --initial-branch=main || fail
        fi
    fi
    makeDir "${binDir}" > /dev/null
    makeDir "${libDir}" > /dev/null

    # Ok, directories are ready, copy and substitute files

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/example'"
    local libraryCall='myExampleLibraryFunction'
    local libraryName="example"
    local libraryNameInitialCap="Example"
    local projectNameClass="${projectName^}"

    copyFileAndSubstituteVars "${packageTemplate}" './rayvn.pkg' quotedName || fail
    copyFileAndSubstituteVars "${libraryTemplate}" './lib/example.sh' projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail
    copyFileAndSubstituteVars "${scriptTemplate}" "./bin/${projectName}" quotedName qualifiedName libraryCall || fail
    chmod +x "./bin/${projectName}" || fail
    copyFileAndSubstituteVars "${readmeTemplate}" './README.md' projectName || fail
    copyFileAndSubstituteVars "${flakeTemplate}" './flake.nix' projectName || fail
    makeDir './formula' > /dev/null
    copyFileAndSubstituteVars "${formulaTemplate}" "./formula/${projectName}.rb" projectName projectNameClass || fail

    # Add and commit

    git add --all
    git commit -m "initial commit"

    # Did we create the repo?

    if (( createdRepo )); then

        # Yes, so we push the changes

        git push -u origin main || fail
        echo "New project files pushed."
        echo
    else
        echo
        show bold "Once you create a repo on GitHub, use the following commands to push it:"
        echo
        echo "   cd ${projectRoot}"
        echo "   git remote add origin https://github.com/YOUR_GH_USER_NAME/${projectName}.git"
        echo "   git push -u origin main"
        echo
    fi
    remindIfNotInPath "${binDir}"
}

remindIfNotInPath() {
    local binDir="$1"
    if [[ ! ":${PATH}:" == *":${binDir}:"* ]]; then
        show "Remember to add" blue "${binDir}" "to your PATH."
    fi
}

newScript() {
    local projectRoot projectName
    local templateFile="${templateDir}/script-template.sh"
    getProjectRoot projectRoot projectName

    local binDir="${projectRoot}/bin"
    local scriptFile="${binDir}/${name}"
    ensureDir "${binDir}"
    assertFileDoesNotExist "${scriptFile}"

    local quotedName="'${projectName}'"
    local qualifiedName=
    local libraryCall='# ...'
    copyFileAndSubstituteVars "${templateFile}" "${scriptFile}" quotedName qualifiedName libraryCall || fail

    chmod +x "${scriptFile}" || fail
    git add "${scriptFile}" || fail

    show "Created" blue "bin/${name}"
    remindIfNotInPath "${binDir}"
}

newLibrary() {
    local projectRoot projectName
    local templateFile="${templateDir}/library-template.sh"
    getProjectRoot projectRoot projectName

    local libDir="${projectRoot}/lib"
    local libraryFile="${libDir}/${name}.sh"
    ensureDir "${libDir}"
    assertFileDoesNotExist "${libraryFile}"

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/${name}'"
    local libraryName="${name}"
    local libraryNameInitialCap="${name^}"

    copyFileAndSubstituteVars "${templateFile}" "${libraryFile}" projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail

    git add "${libraryFile}" || fail

    show "Created" blue "lib/${name}.sh"
}

newTest() {
    local projectRoot projectName
    local templateFile="${templateDir}/test-template.sh"
    getProjectRoot projectRoot projectName

    local testDir="${projectRoot}/test"
    local testFileName="test-${name}.sh"
    local testFile="${testDir}/${testFileName}"
    ensureDir "${testDir}"
    assertFileDoesNotExist "${testFile}"

    cp "${templateFile}" "${testFile}"|| fail
    chmod +x "${testFile}" || fail
    git add "${testFile}" || fail

    show "Created" blue "test/${testFileName}"
}

getProjectRoot() {
    local -n projectRootRef="$1"
    local -n projectNameRef="$2"

    [[ -n ${gitRoot} ]] || bye "${PWD} is not within a project/git repo"
    local _projectRoot="${gitRoot}"
    local packageFile="${_projectRoot}/rayvn.pkg"
    [[ -f "${packageFile}" ]] || bye "${_projectRoot} does not appear to be a rayvn project: no rayvn.pkg file"
    local _projectName="${ baseName ${_projectRoot}; }"
    projectRootRef="${_projectRoot}"
    projectNameRef="${_projectName}"
}

copyFileAndSubstituteVars() {
    local inputFile=$1
    local outputFile=$2
    local varList=("${@:3}")

    [[ -z ${inputFile} || -z ${outputFile} || ${#varList[@]} -eq 0 ]] &&
        fail "Usage: substituteVars inputFile outputFile <varName> [<varName> ...]"

    local sedExprs=()
    for varName in "${varList[@]}"; do
        local value=${!varName}
        # Escape for sed: backslash, ampersand, and delimiter /
        value=${value//\\/\\\\}
        value=${value//&/\\&}
        value=${value//\//\\/}
        sedExprs+=("-e" "s/\${${varName}}/${value}/g")
    done

    gsed "${sedExprs[@]}" "${inputFile}" > "${outputFile}"
}

source rayvn.up
main "$@"
