#!/usr/bin/env rayvn-bash
# shellcheck disable=SC2155
# shellcheck disable=SC2120

usage() {
    echo
    show bold "Create and manage rayvn projects, shared libraries, scripts and tests."
    echo
    show "Usage:" bold blue "${scriptName}" "COMMAND [PROJECT] [PROJECT...] <options>"
    echo
    echo "Commands"
    echo
    echo "    new TYPE NAME    Create a new project, library script or test with the specified NAME."
    echo "    libraries        List libraries."
    echo "    functions        List functions."
    echo "    test             Run tests."
    echo "    theme            Select theme."
    echo "    args             Regenerate the argument parser in a script from its spec."
    echo "    lint             Scan source files for requirement violations."
    echo "    collisions       Check for namespace collisions within and across projects."
    echo "    dependencies     Scan source files and ensure dependency tracking is up to date."
    echo "    index            Generate function indexes for AI agent use."
    echo "    docs             Audit or update function documentation."
    echo "    pages            Generate and preview project gh-pages site."
    echo "    build            Run nix build."
    echo "    release          Create a new release."
    echo "    register         Stake a claim on a project name, if available."
    echo
    echo "Use COMMAND --help for additional details. PROJECT defaults to the current directory's project"
    show "if within one, otherwise to" italic "\${RAYVN_DEFAULT_PROJECT}" "(default: rayvn). Set to empty to require"
    echo "an explicit project name. Most commands accept multiple project names."
    echo
    echo "Options"
    echo
    showCommonOptions 21 true true rayvnEnvVars
    bye "$@"
}

main() {
    init
    parseCommand "$@"
}

init() {
    declare -gA _argsParsedOptions=()
    declare -ga _argsParsedArguments=()
    declare -gAr rayvnEnvVars=(
        ['RAYVN_DEFAULT_PROJECT']="Default project name (default: rayvn)."
    )
}

SECTION="--+-+-----+-++(-++(---++++(---+( ARGUMENT PARSING )+---)++++---)++-)++-+------+-+--"

# rayvn:cli cliSpec
declare -gA cliSpec=(
    ['new | create']='new(project|script|library|test str --local --help|-h)'
    ['args']='args(file --help|-h)'
    ['theme']='theme(--show --help|-h)'
    ['test']='test(--nix --all --help|-h *)'
    ['build']='build(--help|-h *)'
    ['projects']='projects(--help|-h *)'
    ['libraries']='libraries(--help|-h *)'
    ['functions']='functions(--all --help|-h *)'
    ['lint']='lint(--fix --ask --help|-h *)'
    ['collisions']='collisions(--help|-h *)'
    ['deps | dependencies']='dependencies(--fix --help|-h *)'
    ['index']='index(--help|-h *)'
    ['pages']='pages(--help|-h *)'
    ['docs']='docs(audit|update --help|-h *)'
    ['release']='release(--repo:str --help|-h *)'
    ['register']='register(str --help|-h)'
)

newCmdUsage() {
    echo "rayvn new project|script|library|test NAME [--local]"
    echo
    echo "Create a new project, library, script or test from a template."
    echo
    echo "  --local  Skip GitHub repo creation; initialize a local git repo only."
    bye "$@"
}

themeCmdUsage() {
    echo "rayvn theme [--show]"
    echo
    echo "Interactively select a color theme for rayvn output or show the current theme."
    echo
    echo "  --show  Show current theme."
    bye "$@"
}

argsCmdUsage() {
    echo "rayvn args SCRIPT"
    echo
    echo "Regenerate the parser block in SCRIPT from its spec. The script must contain"
    echo "one of the following annotations:"
    echo
    echo "    # rayvn:args specVar [funcName]   argument spec  → parse\${funcName^}Args()"
    echo "    # rayvn:cli  specVar              CLI spec       → parseCommand() + per-command parsers"
    echo
    echo "The spec variable must be defined at global scope (not inside a function)."
    bye "$@"
}

projectsCmdUsage() {
    echo "rayvn projects [PROJECT...]"
    echo
    echo "Show info for one or more projects."
    bye "$@"
}

librariesCmdUsage() {
    echo "rayvn libraries [PROJECT...]"
    echo
    echo "List all libraries for one or more projects."
    bye "$@"
}

functionsCmdUsage() {
    echo "rayvn functions [PROJECT/LIBRARY... | PROJECT... [LIBRARY]] [--all]"
    echo
    echo "List public functions for project libraries."
    echo
    echo "  --all  Also list private (_-prefixed) functions."
    bye "$@"
}

testCmdUsage() {
    echo "rayvn test [PROJECT...] [TEST-NAME...] [--nix] [--all]"
    echo
    echo "Run tests for one or more projects."
    echo
    echo "  --nix  Run tests inside a nix develop shell."
    echo "  --all  Run tests locally and then again inside nix."
    bye "$@"
}

buildCmdUsage() {
    echo "rayvn build [PROJECT...]"
    echo
    echo "  Run nix build for one or more projects."
    bye "$@"
}

indexCmdUsage() {
    echo "rayvn index [-o FILE] [-c FILE] [--no-compact] [--no-hash] [--hash-file FILE]"
    echo
    echo "Generates verbose and compact function indexes used by AI agents (e.g. Claude Code)."
    echo "Run after adding or modifying library functions to keep the indexes current."
    bye "$@"
}

pagesCmdUsage() {
    echo "rayvn pages [PROJECT] [--dir DIR] [--setup | --record [ID...] | --publish | --view]"
    echo
    echo "PROJECT defaults to the current directory's project; only one may be specified."
    echo
    echo "  --setup          First-time setup: create gh-pages branch, worktree, and workflow."
    echo "  --record [ID...] Re-record asciinema casts. Optionally filter by cast ID(s)."
    echo "  --dir DIR        Output directory (default: project's configured worktree)."
    echo "  --publish        Generate pages, then commit and push to gh-pages."
    echo "  --view           Generate pages, then serve locally with Jekyll."
    echo
    echo "Record markup (in any .md file in the pages dir):"
    echo
    echo "  <!-- record id=\"NAME\" cmd=\"COMMAND\" [cmd=\"COMMAND\" ...] [pre=\"CMD\"] [post=\"CMD\"] [prompt=\"PS1\"] -->"
    echo "  {% include asciinema.html id=\"NAME\" src=\"...\" %}"
    echo
    echo "  Each <!-- record --> comment must be paired with a matching {% include asciinema.html %} tag."
    echo
    echo "  id=      Cast identifier (must match the include tag's id= attribute)."
    echo "  cmd=     Command to record. Repeatable; commands are recorded sequentially."
    echo "  pre=     Optional setup command run before recording (not captured)."
    echo "  post=    Optional cleanup command run after recording (not captured)."
    echo "  prompt=  Optional shell prompt string (PS1) shown during recording."
    echo
    bye "$@"
}

lintCmdUsage() {
    echo "rayvn lint [PROJECT...] [--fix] [--ask]"
    echo
    echo "Scan project source files for violations of rayvn's bash requirements."
    echo
    echo "  --fix  Auto-fix all violations that can be corrected automatically."
    echo "  --ask  Interactively prompt whether to fix each file with violations."
    echo
    echo "Note: The old \$( cmd ) command substitution syntax is detected but not auto-fixed." # lint-ok
    echo "      The current \${ cmd; } syntax is significantly more efficient."
    bye "$@"
}


collisionsCmdUsage() {
    echo "rayvn collisions [PROJECT...]"
    echo
    echo "Check for function and global variable name collisions across project libraries."
    bye "$@"
}

dependenciesCmdUsage() {
    echo "rayvn dependencies [--fix] [PROJECT...]"
    echo
    echo "Scan source files for external command dependencies and verify they are declared in flake.nix runtimeDeps."
    echo
    echo "  --fix  Auto-replace 'awk' with 'gawk' and 'sed' with 'gsed' in source files for portability."
    bye "$@"
}

docsCmdUsage() {
    echo "rayvn docs audit | update [PROJECT...] [OPTIONS]"
    echo
    echo "audit [OPTIONS]    Report missing/stale ◇ doc comments."
    echo
    echo "  --release        Exit 1 if any public functions are missing ◇ doc comments."
    echo
    echo "update [OPTIONS]   Generate or fix ◇ doc comments via Claude API."
    echo
    echo "  --dry-run         Print proposed docs without writing any changes."
    echo "  --regen           Regenerate docs for all public functions, not just missing/stale."
    echo "  --missing-only    Only process functions missing a ◇ doc comment."
    echo "  --stale-only      Only process functions with potentially stale docs."
    echo "  --lib NAME        Limit to a single library by name."
    echo "  --since DURATION  Skip functions updated within this duration (e.g. '30m', '2h', '1d')."
    echo "  --delay SECS      Seconds to sleep between API calls to avoid rate limits (default: 5)."
    bye "$@"
}

releaseCmdUsage() {
    echo "rayvn release [PROJECT | --repo 'my-account/my-repo'] VERSION"
    echo
    echo "Create a versioned GitHub release for a project."
    echo
    echo "  --repo ACCOUNT/REPO  Specify the GitHub repository explicitly."
    bye "$@"
}

registerCmdUsage() {
    echo "rayvn register PROJECT"
    echo
    echo "  Stake a claim on a project name on rayvn central."
    bye "$@"
}

# Split parsed arguments into recognized project names and everything else, filling the
# caller's arrays via namerefs. Falls back to the current directory's project (or the
# default) when no projects are given. Args: projectsRef extraArgsRef [argOffset]

resolveProjects() {
    local -n _projectsRef=$1
    local -n _extraArgsRef=$2
    local offset=${3:-0}
    local arg
    for arg in "${_argsParsedArguments[@]:${offset}}"; do
        addIfRayvnExecutable "${arg}" _projectsRef || _extraArgsRef+=("${arg}")
    done
    (( ${#_projectsRef[@]} > 0 )) || detectCurrentProject _projectsRef
}

detectCurrentProject() {
    local -n _detectedProjectsRef=$1
    local dir="${PWD}"
    while [[ -n "${dir}" && "${dir}" != '/' ]]; do
        if [[ -f "${dir}/rayvn.pkg" ]]; then
            local projectName; projectName=${ gawk -F"'" '/^projectName=/{print $2; exit}' "${dir}/rayvn.pkg"; }
            if [[ -n "${projectName}" ]]; then
                if [[ "${projectName}" != rayvn ]]; then
                    _addRayvnProject "${projectName}" "${dir}"
                fi
                _detectedProjectsRef+=( "${projectName}" )
            fi
            return 0
        fi
        dir="${dir%/*}"
    done
    local defaultProject="${RAYVN_DEFAULT_PROJECT-rayvn}"
    if [[ -n ${defaultProject} ]]; then
        _detectedProjectsRef+=( "${defaultProject}" )
    else
        show warning "No project specified" "and" italic "RAYVN_DEFAULT_PROJECT" "is explicitly set to empty."
        show "Specify project name, run from within a project directory or change" italic "RAYVN_DEFAULT_PROJECT" glue "."
    fi
}

addIfRayvnExecutable() {
    local name="$1"
    local -n _addProjectsRef=$2
    local path root rayvnPkgFile
    path="${ type -P "${name}"; }"
    if [[ -n "${path}" ]]; then
        if [[ "${name}" == 'rayvn'  ]]; then
            _addProjectsRef+=( "${name}" )
            return 0
        else
            # Get root directory

            path="${ realpath "${path}"; }"
            path="${path%/}"  # normalize trailing slash
            path="${path%/*}" # strip last component
            root="${path%/*}" # and again to reach root

            # See if there is a rayvn.pkg file

            rayvnPkgFile="${root}/rayvn.pkg"
            [[ -f "${rayvnPkgFile}" ]] || rayvnPkgFile="${root}/share/${name}/rayvn.pkg"
            if [[ -f ${rayvnPkgFile} ]]; then
                _addRayvnProject "${name}" "${root}"
                _addProjectsRef+=( "${name}" )
                return 0
            fi
        fi
    fi
    return 1
}

assertSingleProject() {
    local -n _projectsRef=$1
    (( ${#_projectsRef[@]} > 1 )) && fail "only one project name is supported"
}

assertProjectsSpecified() {
    local -n _projectsRef=$1
    local -n _extraArgsRef=$2
    (( ${#_projectsRef[@]} > 0 )) && return 0
    local candidate="${_extraArgsRef[0]:-}"
    if [[ -n "${candidate}" && "${candidate}" != -* ]]; then
        fail "Unknown project:" blue "${candidate}" "— is its bin directory in PATH?"
    else
        fail "A project name is required (e.g. rayvn, valt, wardn)"
    fi
}

SECTION="--+-+-----+-++(-++(---++++(---+( COMMANDS )+---)++++---)++-)++-+------+-+--"

newCmd() {
    local type=${_argsParsedArguments[0]}
    local name=${_argsParsedArguments[1]}
    local gitRoot; gitRoot=${ git rev-parse --show-toplevel 2> /dev/null; } || gitRoot=''
    local templateDir="${rayvnHome}/templates"
    case ${type} in
        project) newProject ;;
        script)  newScript ;;
        library) newLibrary ;;
        test)    newTest ;;
    esac
}

themeCmd() {
    require 'rayvn/theme'
    if (( _argsParsedOptions['show'] )); then
        header "current theme"
        showCurrentTheme
    else
        setTheme
    fi
}

argsCmd() {
    require 'rayvn/args'
    updateParser "${_argsParsedArguments[0]}"
}

projectsCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    echo
    local project
    for project in "${projects[@]}"; do
        printProject "${project}" "${_rayvnProjects[${project}${_projectRootSuffix}]}"
    done
}

librariesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    local project
    for project in "${projects[@]}"; do
        printLibraries "${project}"
    done
}

functionsCmd() {
    local includePrivate="${_argsParsedOptions['all']:-0}"
    local project
    if [[ -n ${_argsParsedArguments[0]:-} && ${_argsParsedArguments[0]} == */* ]]; then
        local qualifiedLib library
        local -a libNames=() libProjects=()
        for qualifiedLib in "${_argsParsedArguments[@]}"; do
            project="${qualifiedLib%%/*}"
            library="${qualifiedLib##*/}"
            libNames+=("${library}")
            memberOf "${project}" libProjects || libProjects+=("${project}")
        done
        for project in "${libProjects[@]}"; do
            listProjectLibraries "${project}" libNames "${includePrivate}"
        done
    else
        local -a projects=() libNames=()
        resolveProjects projects libNames
        for project in "${projects[@]}"; do
            listProjectLibraries "${project}" libNames "${includePrivate}"
        done
    fi
}

testCmd() {
    local -a projects=() matchArgs=()
    resolveProjects projects matchArgs
    require 'rayvn/test-harness'
    executeTests projects matchArgs "${_argsParsedOptions['nix']:-0}" "${_argsParsedOptions['all']:-0}"
}

buildCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    require 'rayvn/test-harness'
    executeNixBuild projects
}

indexCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    require 'rayvn/index'
    runIndex "${extraArgs[@]}"
}

pagesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    assertProjectsSpecified projects extraArgs
    (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
    require 'rayvn/index'
    runPages "${projects[0]}" "${extraArgs[@]}"
}

lintCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    assertProjectsSpecified projects extraArgs
    (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
    local fixMode=
    (( _argsParsedOptions['fix'] )) && fixMode='--fix'
    (( _argsParsedOptions['ask'] )) && fixMode='--ask'
    require 'rayvn/lint'
    runLint ${fixMode} "${projects[@]}"
}

collisionsCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    require 'rayvn/namespace'
    checkNamespaces "${projects[@]}"
}

dependenciesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    (( ${#projects[@]} == 0 )) && dependenciesCmdUsage
    require 'rayvn/index'
    local fixMode=; (( _argsParsedOptions['fix'] )) && fixMode=fix
    local project result=0
    for project in "${projects[@]}"; do
        findDependencies "${project}" "${fixMode}" || result=1
    done
    return ${result}
}

docsCmd() {
    require 'rayvn/function-docs'
    local subcommand="${_argsParsedArguments[0]}"
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs 1
    case "${subcommand}" in
        audit)  auditDocs  "${extraArgs[@]}" "${projects[@]}" ;;
        update) updateDocs "${extraArgs[@]}" "${projects[@]}" ;;
        *) fail "unknown subcommand: ${subcommand:-<none>}. Use audit or update." ;;
    esac
}

releaseCmd() {
    local version=
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    if (( ${#projects[@]} )); then
        assertSingleProject projects
        version="${extraArgs[0]:-}"
    elif (( ${#extraArgs[@]} == 1 )); then
        projects=(rayvn)
        version="${extraArgs[0]}"
    else
        projects=("${extraArgs[0]:-}")
        version="${extraArgs[1]:-}"
    fi
    [[ -n ${version} ]] || fail "version required"
    local ghRepo="${_argsParsedOptions['repo']:-}"
    if [[ -z ${ghRepo} ]]; then
        local project="${projects[0]}"
        case "${project}" in
            rayvn) ghRepo='phoggy/rayvn' ;;
            valt)  ghRepo='phoggy/valt' ;;
            wardn) ghRepo='phoggy/wardn' ;;
            *) fail "Please specify project using GitHub repo format: --repo 'my-account/my-repo'."
        esac
    fi
    require 'rayvn/release'
    release "${ghRepo}" "${version}"
}

registerCmd() {
    require 'rayvn/central'
    registerProjectOnRayvnCentral "${_argsParsedArguments[0]}" || fail
}

SECTION="--+-+-----+-++(-++(---++++(---+( IMPLEMENTATION )+---)++++---)++-)++-+------+-+--"

printProject() {
    local projectName="$1"
    local projectRoot="$2"
    local version; version="${ projectVersion "${projectName}" true; }"
    echo "${version} -> ${projectRoot}"
}

# Fill the caller's array with the library names of a project. Args: project librariesRef

getLibraries() {
    local project="$1"
    local -n _librariesRef=$2
    local libraryRoot="${_rayvnProjects[${project}${_libraryRootSuffix}]}"
    [[ -n ${libraryRoot} ]] || fail "no libraries found for '${project}' project"
    local file fileName
    _librariesRef=()
    for file in "${libraryRoot}"/*.sh; do
        [[ -e ${file} ]] || fail "no libraries found for '${project}' at ${libraryRoot}"
        fileName="${file##*/}"
        _librariesRef+=("${fileName%.sh}")
    done
}

printLibraries() {
    local project="$1"
    echo
    header "${project} libraries"
    local -a libraries=()
    getLibraries "${project}" libraries
    local library
    for library in "${libraries[@]}"; do
        show primary "  ${project}/${library}"
    done
}

listProjectLibraries() {
    local project="$1"
    local -n _libFilterRef=$2
    local includePrivate=$3
    local libraryRoot="${_rayvnProjects[${project}${_libraryRootSuffix}]}"
    local -a libraries=()
    getLibraries "${project}" libraries
    local library
    for library in "${libraries[@]}"; do
        (( ${#_libFilterRef[@]} > 0 )) && ! memberOf "${library}" _libFilterRef && continue
        listFunctions "${project}" "${library}" "${libraryRoot}/${library}.sh" "${includePrivate}"
    done
}

listFunctions() {
    local project=$1
    local library="$2"
    local libraryFile="$3"
    local includePrivate=$4
    local libraryName="${project}/${library}"
    local functions=()
    local function

    getFunctions "${libraryFile}" functions

    header "${libraryName} functions"

    for function in "${functions[@]}"; do
        [[ ${function} != _* ]] && show primary "  ${function}"
    done
    if (( includePrivate )); then
        for function in "${functions[@]}"; do
            [[ ${function} == _* ]] && show italic red "  ${function}"
        done
    fi
}

getFunctions() {
    local sourcePath="$1"
    local -n arrayRef="$2"
    local _functions
    assertFile "${sourcePath}"
    _functions=${ bash --norc --noprofile -c "source '${sourcePath}' 2> /dev/null; compgen -A function;"; } || return 1
    _functions=(${ printf '%s\n' "${_functions[@]}" | sort; })
    arrayRef=("${_functions[@]}")
}

printVersion() {
    local verbose="${1:-}"
    projectVersion rayvn "${verbose}"
}

newProject() {
    [[ "${name}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || fail "sorry, '${name}' is not a valid bash identifier"
    [[ -n ${gitRoot} ]] && fail "${PWD} is within an existing project/git repo"
    local projectName="${name}"
    local projectRoot="${PWD}/${projectName}"
    assertFileDoesNotExist "${projectRoot}"
    local binDir="${projectRoot}/bin"
    local libDir="${projectRoot}/lib"
    local packageTemplate="${templateDir}/package-template.sh"
    local scriptTemplate="${templateDir}/script-template.sh"
    local libraryTemplate="${templateDir}/library-template.sh"
    local readmeTemplate="${templateDir}/readme-template.md"
    local flakeTemplate="${templateDir}/flake-template.nix"
    local formulaTemplate="${templateDir}/formula-template.rb"

    echo
    show bold "Creating project '${projectName}' in" blue "'${PWD}'"
    echo

    declare -i createdRepo=0
    local choiceIndex formulaFile repoUrl

    if (( _argsParsedOptions['local'] )); then
        # --local flag: skip GitHub, just create local git repo
        makeDir "${projectRoot}" > /dev/null
        cd "${projectRoot}" || fail
        git init --initial-branch=main || fail
    else
        require 'rayvn/prompt' 'rayvn/central'
        confirm "Create new GitHub repo for project '${projectName}'?" yes no choiceIndex || bye
        if (( choiceIndex == 0 )); then
            if ! gh auth status --active &> /dev/null; then
                confirm "Need to authenticate. Do you have a GitHub account?" y n choiceIndex || bye
                if (( choiceIndex == 0 )); then
                    gh auth login || exit
                else
                    bye "Please go to https://github.com/ and create an account first."
                fi
            fi
            echo
            gh repo create "${projectName}" --add-readme --private --clone || fail
            cd "${projectRoot}" || fail
            repoUrl="${ git remote get-url origin; }"
            registerProjectOnRayvnCentral "${projectName}" || fail
            createdRepo=1
        else
            echo
            makeDir "${projectRoot}" > /dev/null
            cd "${projectRoot}" || fail
            git init --initial-branch=main || fail
        fi
    fi
    makeDir "${binDir}" > /dev/null
    makeDir "${libDir}" > /dev/null

    # Ok, directories are ready, copy and substitute files

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/example'"
    local libraryCall='myExampleLibraryFunction'
    local libraryName="example"
    local libraryNameInitialCap="Example"
    local projectNameClass="${projectName^}"

    copyFileAndSubstituteVars "${packageTemplate}" './rayvn.pkg' quotedName || fail
    copyFileAndSubstituteVars "${libraryTemplate}" './lib/example.sh' projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail
    copyFileAndSubstituteVars "${scriptTemplate}" "./bin/${projectName}" quotedName qualifiedName libraryCall || fail
    chmod +x "./bin/${projectName}" || fail
    copyFileAndSubstituteVars "${readmeTemplate}" './README.md' projectName || fail
    copyFileAndSubstituteVars "${flakeTemplate}" './flake.nix' projectName || fail
    makeDir './formula' > /dev/null
    copyFileAndSubstituteVars "${formulaTemplate}" "./formula/${projectName}.rb" projectName projectNameClass || fail

    # Add and commit

    git add --all
    git commit -m "initial commit"

    # Did we create the repo?

    if (( createdRepo )); then

        # Yes, so we push the changes

        git push -u origin main || fail
        echo "New project files pushed."
        echo
    else
        echo
        show bold "Once you create a repo on GitHub, use the following commands to push it:"
        echo
        echo "   cd ${projectRoot}"
        echo "   git remote add origin https://github.com/YOUR_GH_USER_NAME/${projectName}.git"
        echo "   git push -u origin main"
        echo
    fi

    show "Please update the" primary "projectDescription" "property in the" blue "rayvn.pkg" "file."
    remindIfNotInPath "${binDir}"
}

remindIfNotInPath() {
    local binDir="$1"
    if [[ ! ":${PATH}:" == *":${binDir}:"* ]]; then
        show "Remember to add" blue "${binDir}" "to your PATH."
    fi
}

newScript() {
    local projectRoot projectName
    local templateFile="${templateDir}/script-template.sh"
    getProjectRoot projectRoot projectName

    local binDir="${projectRoot}/bin"
    local scriptFile="${binDir}/${name}"
    ensureDir "${binDir}"
    assertFileDoesNotExist "${scriptFile}"

    local quotedName="'${projectName}'"
    local qualifiedName=
    local libraryCall='# ...'
    copyFileAndSubstituteVars "${templateFile}" "${scriptFile}" quotedName qualifiedName libraryCall || fail

    chmod +x "${scriptFile}" || fail
    git add "${scriptFile}" || fail

    show "Created" blue "bin/${name}"
    remindIfNotInPath "${binDir}"
}

newLibrary() {
    local projectRoot projectName
    local templateFile="${templateDir}/library-template.sh"
    getProjectRoot projectRoot projectName

    local libDir="${projectRoot}/lib"
    local libraryFile="${libDir}/${name}.sh"
    ensureDir "${libDir}"
    assertFileDoesNotExist "${libraryFile}"

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/${name}'"
    local libraryName="${name}"
    local libraryNameInitialCap="${name^}"

    copyFileAndSubstituteVars "${templateFile}" "${libraryFile}" projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail

    git add "${libraryFile}" || fail

    show "Created" blue "lib/${name}.sh"
}

newTest() {
    local projectRoot projectName
    local templateFile="${templateDir}/test-template.sh"
    getProjectRoot projectRoot projectName

    local testDir="${projectRoot}/test"
    local testFileName="test-${name}.sh"
    local testFile="${testDir}/${testFileName}"
    ensureDir "${testDir}"
    assertFileDoesNotExist "${testFile}"

    cp "${templateFile}" "${testFile}"|| fail
    chmod +x "${testFile}" || fail
    git add "${testFile}" || fail

    show "Created" blue "test/${testFileName}"
}

getProjectRoot() {
    local -n projectRootRef="$1"
    local -n projectNameRef="$2"

    [[ -n ${gitRoot} ]] || bye "${PWD} is not within a project/git repo"
    local _projectRoot="${gitRoot}"
    local packageFile="${_projectRoot}/rayvn.pkg"
    [[ -f "${packageFile}" ]] || bye "${_projectRoot} does not appear to be a rayvn project: no rayvn.pkg file"
    local _projectName; _projectName="${ baseName ${_projectRoot}; }"
    projectRootRef="${_projectRoot}"
    projectNameRef="${_projectName}"
}

copyFileAndSubstituteVars() {
    local inputFile=$1
    local outputFile=$2
    local varList=("${@:3}")

    { [[ -z ${inputFile} || -z ${outputFile} ]] || (( ${#varList[@]} == 0 )); } &&
        fail "Usage: substituteVars inputFile outputFile <varName> [<varName> ...]"

    local sedExprs=()
    for varName in "${varList[@]}"; do
        local value=${!varName}
        # Escape for sed: backslash, ampersand, and delimiter /
        value=${value//\\/\\\\}
        value=${value//&/\\&}
        value=${value//\//\\/}
        sedExprs+=("-e" "s/\${${varName}}/${value}/g")
    done

    gsed "${sedExprs[@]}" "${inputFile}" > "${outputFile}"
}

ARGS_PARSER_BEGIN="━━━━🚫━━━━━━━━━━━━━━━━━━━━━━━ 🚫 🔽 BEGIN generated code: DO NOT EDIT 🔽 🚫 ━━━━━━━━━━━━━━━━━━━━━━━━━━🚫━━━━"

parseCommand() {
    _argsParsedOptions=()
    _argsParsedArguments=()
    parseCommonOptions rayvn "$@"; shift $?
    case "$1" in
        register) shift; parseRegisterArgs "$@"; (( _argsParsedOptions['help'] )) && registerCmdUsage || registerCmd ;;
        index) shift; parseIndexArgs "$@"; (( _argsParsedOptions['help'] )) && indexCmdUsage || indexCmd ;;
        docs) shift; parseDocsArgs "$@"; (( _argsParsedOptions['help'] )) && docsCmdUsage || docsCmd ;;
        collisions) shift; parseCollisionsArgs "$@"; (( _argsParsedOptions['help'] )) && collisionsCmdUsage || collisionsCmd ;;
        args) shift; parseArgsArgs "$@"; (( _argsParsedOptions['help'] )) && argsCmdUsage || argsCmd ;;
        functions) shift; parseFunctionsArgs "$@"; (( _argsParsedOptions['help'] )) && functionsCmdUsage || functionsCmd ;;
        new | create) shift; parseNewArgs "$@"; (( _argsParsedOptions['help'] )) && newCmdUsage || newCmd ;;
        projects) shift; parseProjectsArgs "$@"; (( _argsParsedOptions['help'] )) && projectsCmdUsage || projectsCmd ;;
        deps | dependencies) shift; parseDependenciesArgs "$@"; (( _argsParsedOptions['help'] )) && dependenciesCmdUsage || dependenciesCmd ;;
        pages) shift; parsePagesArgs "$@"; (( _argsParsedOptions['help'] )) && pagesCmdUsage || pagesCmd ;;
        build) shift; parseBuildArgs "$@"; (( _argsParsedOptions['help'] )) && buildCmdUsage || buildCmd ;;
        release) shift; parseReleaseArgs "$@"; (( _argsParsedOptions['help'] )) && releaseCmdUsage || releaseCmd ;;
        theme) shift; parseThemeArgs "$@"; (( _argsParsedOptions['help'] )) && themeCmdUsage || themeCmd ;;
        lint) shift; parseLintArgs "$@"; (( _argsParsedOptions['help'] )) && lintCmdUsage || lintCmd ;;
        libraries) shift; parseLibrariesArgs "$@"; (( _argsParsedOptions['help'] )) && librariesCmdUsage || librariesCmd ;;
        test) shift; parseTestArgs "$@"; (( _argsParsedOptions['help'] )) && testCmdUsage || testCmd ;;
        *) usage "unknown command: $1" ;;
    esac
}

parseRegisterArgs() {
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) (( _argIndex == 0 )) || unknownArg "$1"; _argsParsedArguments+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _argsParsedOptions['help'] || _argIndex >= 1 )) || fail "missing required argument"
}

parseIndexArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseDocsArgs() {
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) (( _argIndex == 0 )) && { [[ "|audit|update|" == *"|$1|"* ]] || fail "$1 must be one of: audit|update"; }; _argsParsedArguments+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _argsParsedOptions['help'] || _argIndex >= 1 )) || fail "missing required argument"
}

parseCollisionsArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseArgsArgs() {
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) (( _argIndex == 0 )) && assertFile "$1" || unknownArg "$1"; _argsParsedArguments+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _argsParsedOptions['help'] || _argIndex >= 1 )) || fail "missing required argument"
}

parseFunctionsArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            --all) _argsParsedOptions+=([all]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseNewArgs() {
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --local) _argsParsedOptions+=([local]="1"); shift ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *)
                (( _argIndex < 2 )) || unknownArg "$1"
                (( _argIndex == 0 )) && { [[ "|project|script|library|test|" == *"|$1|"* ]] || fail "$1 must be one of: project|script|library|test"; }
                _argsParsedArguments+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _argsParsedOptions['help'] || _argIndex >= 2 )) || fail "missing required arguments: expected at least 2"
}

parseProjectsArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseDependenciesArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --fix) _argsParsedOptions+=([fix]="1"); shift ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parsePagesArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseBuildArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseReleaseArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --repo) [[ -z "$2" || ( "$2" == -* && "$2" =~ ^(-h|--repo|--help)$ ) ]] && fail "missing value for --repo"; _argsParsedOptions+=([repo]="$2"); shift 2 ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseThemeArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --show) _argsParsedOptions+=([show]="1"); shift ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) unknownArg "$1" ;;
        esac
    done
}

parseLintArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --fix) _argsParsedOptions+=([fix]="1"); shift ;;
            --ask) _argsParsedOptions+=([ask]="1"); shift ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseLibrariesArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

parseTestArgs() {
    while (( $# > 0 )); do
        case "$1" in
            --nix) _argsParsedOptions+=([nix]="1"); shift ;;
            --help | -h) _argsParsedOptions+=([help]="1"); shift ;;
            --all) _argsParsedOptions+=([all]="1"); shift ;;
            *) _argsParsedArguments+=("$1"); shift ;;
        esac
    done
}

