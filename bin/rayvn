parseLintArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=lintCmdUsage
    local _mutex
    while (( $# > 0 )); do
        case "$1" in
            --ask) _opts+=(['ask']="1"); shift ;;
            --ask=*) fail "--ask does not accept a value" ;;
            --fix) _opts+=(['fix']="1"); shift ;;
            --fix=*) fail "--fix does not accept a value" ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --) shift; _args+=("$@"); break ;;
            *) _args+=("$1"); shift ;;
        esac
    done
    _mutex=0
    [[ -v _opts['fix'] ]] && (( _mutex++ ))
    [[ -v _opts['ask'] ]] && (( _mutex++ ))
    (( _opts['help'] || _mutex <= 1 )) || fail "at most one of --fix | --ask may be specified"
    declare -g _failHandler="${_prevFailHandler}"
}

