    option "--fix" "Auto-fix all violations that can be corrected automatically." 16
    option "--ask" "Interactively prompt whether to fix each file with violations." 16
    option "--help, -h" "Print this help message." 16
    declare -F lintCmdUsageExtra > /dev/null && lintCmdUsageExtra
    bye "$@"
