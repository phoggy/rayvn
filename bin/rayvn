#!/usr/bin/env rayvn-bash
# shellcheck disable=SC2155
# shellcheck disable=SC2120

usage() {
    echo
    show bold "Create and manage rayvn projects, shared libraries, scripts and tests."
    echo
    show "Usage:" bold blue "${scriptName}" "COMMAND [PROJECT] [PROJECT...] <options>"
    echo
    echo "Commands"
    echo
    echo "    new TYPE NAME    Create a new project, library script or test with the specified NAME."
    echo "    libraries        List libraries."
    echo "    functions        List functions."
    echo "    test             Run tests."
    echo "    theme            Select theme."
    echo "    args             Regenerate the argument parser in a script from its spec."
    echo "    lint             Scan source files for requirement violations."
    echo "    collisions       Check for namespace collisions within and across projects."
    echo "    dependencies     Scan source files and ensure dependency tracking is up to date."
    echo "    index            Generate function indexes for AI agent use."
    echo "    docs audit       Audit function documentation."
    echo "    docs update      Update function documentation."
    echo "    pages            Generate and preview project gh-pages site."
    echo "    build            Run nix build."
    echo "    release          Create a new release."
    echo "    register         Stake a claim on a project name, if available."
    echo
    echo "Use COMMAND --help for additional details. PROJECT defaults to the current directory's project"
    show "if within one, otherwise to" italic "\${RAYVN_DEFAULT_PROJECT}" "(default: rayvn). Set to empty to require"
    echo "an explicit project name. Most commands accept multiple project names."
    echo
    echo "Options"
    echo
    showCommonOptions 21 true true rayvnEnvVars
    bye "$@"
}

main() {
    init
    parseCommand "$@"
}

init() {
    declare -gA _opts=()
    declare -ga _args=()
    declare -gAr rayvnEnvVars=(
        ['RAYVN_DEFAULT_PROJECT']="Default project name (default: rayvn)."
    )
}

SECTION="--+-+-----+-++(-++(---++++(---+( ARGUMENT PARSING )+---)++++---)++-)++-+------+-+--"

# rayvn:cli cliSpec
declare -gA cliSpec=(
    # Create a new project, library, script or test from a template.
    #   TYPE     What to create: a project, script, library or test.
    #   NAME     The name to create.
    #   --local  Skip GitHub repo creation; initialize a local git repo only.
    ['new | create']='new(project|script|library|test str --local --help|-h)'

    # Regenerate the parser block in SCRIPT from its spec, or with --check report
    # whether the committed block is stale without modifying the file.
    #   SCRIPT   Path to the script to update, or a bare executable name (e.g. 'rayvn'); must contain a rayvn:args or rayvn:cli annotation.
    #   --check  Report drift without updating the file.
    #
    # Annotation formats:
    #
    #     # rayvn:args specVar [funcName]   → parse${funcName^}Args()
    #     # rayvn:cli  specVar              → parseCommand() + per-command parsers
    #
    # The spec variable must be defined at global scope (not inside a function).
    ['args']='args(exe --check --help|-h)'

    # Interactively select a color theme for rayvn output or show the current theme.
    #   --show  Show current theme.
    ['theme']='theme(--show --help|-h)'

    # Run tests for one or more projects.
    #   ARGS...  Project names and/or test name patterns; prefix a pattern with '-' to exclude it.
    #   --nix    Run tests inside a nix develop shell.
    #   --all    Run tests locally and then again inside nix.
    ['test']='test(--nix --all --help|-h *)'

    # Run nix build for one or more projects.
    #   PROJECT...  Project names (default: current project).
    ['build']='build(--help|-h *)'

    # Show info for one or more projects.
    #   PROJECT...  Project names (default: current project).
    ['projects']='projects(--help|-h *)'

    # List all libraries for one or more projects.
    #   PROJECT...  Project names (default: current project).
    ['libraries']='libraries(--help|-h *)'

    # List public functions for project libraries.
    #   ARGS...  PROJECT/LIBRARY qualified names, or project names optionally followed by library names.
    #   --all    Also list private (_-prefixed) functions.
    ['functions']='functions(--all --help|-h *)'

    # Scan project source files for violations of rayvn's bash requirements.
    #   PROJECT...  Project names (default: current project); only one may be specified.
    #   --fix       Auto-fix all violations that can be corrected automatically.
    #   --ask       Interactively prompt whether to fix each file with violations.
    ['lint']='lint([--fix|--ask] --help|-h *)'

    # Check for function and global variable name collisions across project libraries.
    #   PROJECT...  Project names (default: current project).
    ['collisions']='collisions(--help|-h *)'

    # Scan source files for external command dependencies and verify they are declared in flake.nix runtimeDeps.
    #   PROJECT...  Project names (default: current project).
    #   --fix       Auto-replace 'awk' with 'gawk' and 'sed' with 'gsed' in source files for portability.
    ['deps | dependencies']='dependencies(--fix --help|-h *)'

    # Generate verbose and compact function indexes used by AI agents (e.g. Claude Code).
    # Run after adding or modifying library functions to keep the indexes current.
    #   PROJECT...    Project names (default: current project).
    #   --output|-o   Verbose index output file (default: ~/.config/rayvn/rayvn-functions.md).
    #   --compact|-c  Compact index output file (default: ~/.config/rayvn/rayvn-functions-compact.txt).
    #   --no-compact  Skip generating the compact index.
    #   --no-hash     Skip function hash tracking.
    #   --hash-file   Function hash file (default: ~/.config/rayvn/rayvn-function-hashes.txt).
    ['index']='index(--output|-o:str --compact|-c:str --no-compact --no-hash --hash-file:str --help|-h *)'

    # Generate and preview the project's gh-pages site.
    #   PROJECT   Project name (default: current directory's project); only one may be specified.
    #   --dir     Output directory (default: project's configured worktree).
    #   --record  Re-record asciinema casts; optionally filter by cast ID(s), all if omitted.
    #   --setup   First-time setup: create gh-pages branch, worktree, and workflow.
    #   --publish Generate pages, then commit and push to gh-pages.
    #   --view    Generate pages, then serve locally with Jekyll.
    #
    # Record markup (in any .md file in the pages dir):
    #
    #   <!-- record id="NAME" cmd="COMMAND" [cmd="COMMAND" ...]
    #        [pre="CMD"] [post="CMD"] [prompt="PS1"] -->
    #   {% include asciinema.html id="NAME" src="..." %}
    #
    #   Each <!-- record --> comment must be paired with a matching
    #   {% include asciinema.html %} tag.
    #
    #   id=      Cast identifier (must match the include tag's id= attribute).
    #   cmd=     Command to record. Repeatable; commands are recorded sequentially.
    #   pre=     Optional setup command run before recording (not captured).
    #   post=    Optional cleanup command run after recording (not captured).
    #   prompt=  Optional shell prompt string (PS1) shown during recording.
    ['pages']='pages(str? --dir:str --record:str* [--setup|--record|--publish|--view] --help|-h)'

    # Report missing/stale ◇ doc comments.
    #   PROJECT...  Project names to audit (default: all loaded projects).
    #   --release   Exit 1 if any public functions are missing ◇ doc comments.
    ['docs audit']='docsAudit(--release --help|-h *)'

    # Generate or fix ◇ doc comments via Claude API.
    #   PROJECT...      Project names to limit scope (default: all loaded projects).
    #   --dry-run       Print proposed docs without writing any changes.
    #   --regen         Regenerate docs for all public functions, not just missing/stale.
    #   --missing-only  Only process functions missing a ◇ doc comment.
    #   --stale-only    Only process functions with potentially stale docs.
    #   --lib           Limit to a single library by name.
    #   --since         Skip functions updated within this duration (e.g. '30m', '2h', '1d').
    #   --delay         Seconds to sleep between API calls to avoid rate limits.
    ['docs update']='docsUpdate(--dry-run --regen --missing-only --stale-only --lib:str --since:str --delay:+int=5 --help|-h *)'

    # Create a versioned GitHub release for the current directory's project. The GitHub repository is derived from
    # the git 'origin' remote and confirmed before releasing.
    #   VERSION  The version to release, e.g. '1.2.3'; must be greater than the current version.
    ['release']='release(version --help|-h)'

    # Stake a claim on a project name on rayvn central.
    #   NAME  The project name to register.
    ['register']='register(str --help|-h)'
)

# Split parsed arguments into recognized project names and everything else, filling the
# caller's arrays via namerefs. Falls back to the current directory's project (or the
# default) when no projects are given. Args: projectsRef extraArgsRef [argOffset]

resolveProjects() {
    local -n _projectsRef=$1
    local -n _extraArgsRef=$2
    local offset=${3:-0}
    local arg
    for arg in "${_args[@]:${offset}}"; do
        addIfRayvnExecutable "${arg}" _projectsRef || _extraArgsRef+=("${arg}")
    done
    (( ${#_projectsRef[@]} > 0 )) || detectCurrentProject _projectsRef
}

detectCurrentProject() {
    local -n _detectedProjectsRef=$1
    local dir="${PWD}"
    while [[ -n "${dir}" && "${dir}" != '/' ]]; do
        if [[ -f "${dir}/rayvn.pkg" ]]; then
            local projectName; projectName=${ gawk -F"'" '/^projectName=/{print $2; exit}' "${dir}/rayvn.pkg"; }
            if [[ -n "${projectName}" ]]; then
                if [[ "${projectName}" != rayvn ]]; then
                    _addRayvnProject "${projectName}" "${dir}"
                fi
                _detectedProjectsRef+=( "${projectName}" )
            fi
            return 0
        fi
        dir="${dir%/*}"
    done
    local defaultProject="${RAYVN_DEFAULT_PROJECT-rayvn}"
    if [[ -n ${defaultProject} ]]; then
        _detectedProjectsRef+=( "${defaultProject}" )
    else
        show warning "No project specified" "and" italic "RAYVN_DEFAULT_PROJECT" "is explicitly set to empty."
        show "Specify project name, run from within a project directory or change" italic "RAYVN_DEFAULT_PROJECT" glue "."
    fi
}

addIfRayvnExecutable() {
    local name="$1"
    local -n _addProjectsRef=$2
    local path root rayvnPkgFile
    path="${ type -P "${name}"; }"
    if [[ -n "${path}" ]]; then
        if [[ "${name}" == 'rayvn'  ]]; then
            _addProjectsRef+=( "${name}" )
            return 0
        else
            # Get root directory

            path="${ realpath "${path}"; }"
            path="${path%/}"  # normalize trailing slash
            path="${path%/*}" # strip last component
            root="${path%/*}" # and again to reach root

            # See if there is a rayvn.pkg file

            rayvnPkgFile="${root}/rayvn.pkg"
            [[ -f "${rayvnPkgFile}" ]] || rayvnPkgFile="${root}/share/${name}/rayvn.pkg"
            if [[ -f ${rayvnPkgFile} ]]; then
                _addRayvnProject "${name}" "${root}"
                _addProjectsRef+=( "${name}" )
                return 0
            fi
        fi
    fi
    return 1
}

assertSingleProject() {
    local -n _projectsRef=$1
    (( ${#_projectsRef[@]} > 1 )) && fail "only one project name is supported"
}

assertProjectsSpecified() {
    local -n _projectsRef=$1
    local -n _extraArgsRef=$2
    (( ${#_projectsRef[@]} > 0 )) && return 0
    local candidate="${_extraArgsRef[0]:-}"
    if [[ -n "${candidate}" && "${candidate}" != -* ]]; then
        fail "Unknown project:" blue "${candidate}" "— is its bin directory in PATH?"
    else
        fail "A project name is required (e.g. rayvn, valt, wardn)"
    fi
}

SECTION="--+-+-----+-++(-++(---++++(---+( COMMANDS )+---)++++---)++-)++-+------+-+--"

newCmd() {
    local type=${_args[0]}
    local name=${_args[1]}
    local gitRoot; gitRoot=${ git rev-parse --show-toplevel 2> /dev/null; } || gitRoot=''
    local templateDir="${rayvnHome}/templates"
    case ${type} in
        project) newProject ;;
        script)  newScript ;;
        library) newLibrary ;;
        test)    newTest ;;
    esac
}

themeCmd() {
    require 'rayvn/theme'
    if (( _opts['show'] )); then
        header "current theme"
        showCurrentTheme
    else
        setTheme
    fi
}

argsCmd() {
    require 'rayvn/args'
    local checkFlag=; (( _opts['check'] )) && checkFlag='--check'
    updateParser ${checkFlag} "${_args[0]}"
}

projectsCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    echo
    local project
    for project in "${projects[@]}"; do
        printProject "${project}" "${_rayvnProjects[${project}${_projectRootSuffix}]}"
    done
}

librariesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    local project
    for project in "${projects[@]}"; do
        printLibraries "${project}"
    done
}

functionsCmd() {
    local includePrivate="${_opts['all']:-0}"
    local project
    if [[ -n ${_args[0]:-} && ${_args[0]} == */* ]]; then
        local qualifiedLib library
        local -a libNames=() libProjects=()
        for qualifiedLib in "${_args[@]}"; do
            project="${qualifiedLib%%/*}"
            library="${qualifiedLib##*/}"
            libNames+=("${library}")
            memberOf "${project}" libProjects || libProjects+=("${project}")
        done
        for project in "${libProjects[@]}"; do
            listProjectLibraries "${project}" libNames "${includePrivate}"
        done
    else
        local -a projects=() libNames=()
        resolveProjects projects libNames
        for project in "${projects[@]}"; do
            listProjectLibraries "${project}" libNames "${includePrivate}"
        done
    fi
}

testCmd() {
    local -a projects=() matchArgs=()
    resolveProjects projects matchArgs
    require 'rayvn/test-harness'
    executeTests projects matchArgs "${_opts['nix']:-0}" "${_opts['all']:-0}"
}

buildCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    require 'rayvn/test-harness'
    executeNixBuild projects
}

indexCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    (( ${#extraArgs[@]} == 0 )) || unknownArg "${extraArgs[0]}"
    require 'rayvn/index'
    local -a indexArgs=()
    [[ -v _opts['output'] ]] && indexArgs+=(--output "${_opts['output']}")
    [[ -v _opts['compact'] ]] && indexArgs+=(--compact "${_opts['compact']}")
    [[ -v _opts['no-compact'] ]] && indexArgs+=(--no-compact)
    [[ -v _opts['no-hash'] ]] && indexArgs+=(--no-hash)
    [[ -v _opts['hash-file'] ]] && indexArgs+=(--hash-file "${_opts['hash-file']}")
    runIndex "${indexArgs[@]}"
}

pagesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    assertProjectsSpecified projects extraArgs
    (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
    (( ${#extraArgs[@]} == 0 )) || unknownArg "${extraArgs[0]}"
    require 'rayvn/index'

    local -a pagesArgs=()
    [[ -v _opts['dir'] ]] && pagesArgs+=(--dir "${_opts['dir']}")
    (( _opts['setup'] )) && pagesArgs+=(--setup)
    (( _opts['publish'] )) && pagesArgs+=(--publish)
    (( _opts['view'] )) && pagesArgs+=(--view)
    if [[ -v _opts['record'] ]]; then
        pagesArgs+=(--record)
        pagesArgs+=("${_optListRecord[@]}")
    fi
    runPages "${projects[0]}" "${pagesArgs[@]}"
}

lintCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    assertProjectsSpecified projects extraArgs
    (( ${#projects[@]} == 1 )) || fail "Only one project at a time is supported"
    local fixMode=
    (( _opts['fix'] )) && fixMode='--fix'
    (( _opts['ask'] )) && fixMode='--ask'
    require 'rayvn/lint'
    runLint ${fixMode} "${projects[@]}"
}

collisionsCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    require 'rayvn/namespace'
    checkNamespaces "${projects[@]}"
}

dependenciesCmd() {
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    (( ${#projects[@]} == 0 )) && dependenciesCmdUsage
    require 'rayvn/index'
    local fixMode=; (( _opts['fix'] )) && fixMode=fix
    local project result=0
    for project in "${projects[@]}"; do
        findDependencies "${project}" "${fixMode}" || result=1
    done
    return ${result}
}

docsAuditCmd() {
    require 'rayvn/function-docs'
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    (( ${#extraArgs[@]} == 0 )) || unknownArg "${extraArgs[0]}"
    local -a auditArgs=()
    (( _opts['release'] )) && auditArgs+=(--release)
    auditArgs+=("${projects[@]}")
    auditDocs "${auditArgs[@]}"
}

docsUpdateCmd() {
    require 'rayvn/function-docs'
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs
    (( ${#extraArgs[@]} == 0 )) || unknownArg "${extraArgs[0]}"
    local -a updateArgs=()
    (( _opts['dry-run'] )) && updateArgs+=(--dry-run)
    (( _opts['regen'] )) && updateArgs+=(--regen)
    (( _opts['missing-only'] )) && updateArgs+=(--missing-only)
    (( _opts['stale-only'] )) && updateArgs+=(--stale-only)
    [[ -v _opts['lib'] ]] && updateArgs+=(--lib "${_opts['lib']}")
    [[ -v _opts['since'] ]] && updateArgs+=(--since "${_opts['since']}")
    updateArgs+=(--delay "${_opts['delay']}")
    updateArgs+=("${projects[@]}")
    updateDocs "${updateArgs[@]}"
}

releaseCmd() {
    local version="${_args[0]}"
    local -a projects=() extraArgs=()
    resolveProjects projects extraArgs 1
    assertProjectsSpecified projects extraArgs
    require 'rayvn/release'
    release "${projects[0]}" "${version}"
}

registerCmd() {
    require 'rayvn/central'
    registerProjectOnRayvnCentral "${_args[0]}" || fail
}

SECTION="--+-+-----+-++(-++(---++++(---+( IMPLEMENTATION )+---)++++---)++-)++-+------+-+--"

printProject() {
    local projectName="$1"
    local projectRoot="$2"
    local version; version="${ projectVersion "${projectName}" true; }"
    echo "${version} -> ${projectRoot}"
}

# Fill the caller's array with the library names of a project. Args: project librariesRef

getLibraries() {
    local project="$1"
    local -n _librariesRef=$2
    local libraryRoot="${_rayvnProjects[${project}${_libraryRootSuffix}]}"
    [[ -n ${libraryRoot} ]] || fail "no libraries found for '${project}' project"
    local file fileName
    _librariesRef=()
    for file in "${libraryRoot}"/*.sh; do
        [[ -e ${file} ]] || fail "no libraries found for '${project}' at ${libraryRoot}"
        fileName="${file##*/}"
        _librariesRef+=("${fileName%.sh}")
    done
}

printLibraries() {
    local project="$1"
    echo
    header "${project} libraries"
    local -a libraries=()
    getLibraries "${project}" libraries
    local library
    for library in "${libraries[@]}"; do
        show primary "  ${project}/${library}"
    done
}

listProjectLibraries() {
    local project="$1"
    local -n _libFilterRef=$2
    local includePrivate=$3
    local libraryRoot="${_rayvnProjects[${project}${_libraryRootSuffix}]}"
    local -a libraries=()
    getLibraries "${project}" libraries
    local library
    for library in "${libraries[@]}"; do
        (( ${#_libFilterRef[@]} > 0 )) && ! memberOf "${library}" _libFilterRef && continue
        listFunctions "${project}" "${library}" "${libraryRoot}/${library}.sh" "${includePrivate}"
    done
}

listFunctions() {
    local project=$1
    local library="$2"
    local libraryFile="$3"
    local includePrivate=$4
    local libraryName="${project}/${library}"
    local functions=()
    local function

    getFunctions "${libraryFile}" functions

    header "${libraryName} functions"

    for function in "${functions[@]}"; do
        [[ ${function} != _* ]] && show primary "  ${function}"
    done
    if (( includePrivate )); then
        for function in "${functions[@]}"; do
            [[ ${function} == _* ]] && show italic red "  ${function}"
        done
    fi
}

getFunctions() {
    local sourcePath="$1"
    local -n arrayRef="$2"
    local _functions
    assertFile "${sourcePath}"
    _functions=${ bash --norc --noprofile -c "source '${sourcePath}' 2> /dev/null; compgen -A function;"; } || return 1
    _functions=(${ printf '%s\n' "${_functions[@]}" | sort; })
    arrayRef=("${_functions[@]}")
}

printVersion() {
    local verbose="${1:-}"
    projectVersion rayvn "${verbose}"
}

newProject() {
    [[ "${name}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || fail "sorry, '${name}' is not a valid bash identifier"
    [[ -n ${gitRoot} ]] && fail "${PWD} is within an existing project/git repo"
    local projectName="${name}"
    local projectRoot="${PWD}/${projectName}"
    assertFileDoesNotExist "${projectRoot}"
    local binDir="${projectRoot}/bin"
    local libDir="${projectRoot}/lib"
    local packageTemplate="${templateDir}/package-template.sh"
    local scriptTemplate="${templateDir}/script-template.sh"
    local libraryTemplate="${templateDir}/library-template.sh"
    local readmeTemplate="${templateDir}/readme-template.md"
    local flakeTemplate="${templateDir}/flake-template.nix"
    local formulaTemplate="${templateDir}/formula-template.rb"

    echo
    show bold "Creating project '${projectName}' in" blue "'${PWD}'"
    echo

    declare -i createdRepo=0
    local choiceIndex formulaFile repoUrl

    if (( _opts['local'] )); then
        # --local flag: skip GitHub, just create local git repo
        makeDir "${projectRoot}" > /dev/null
        cd "${projectRoot}" || fail
        git init --initial-branch=main || fail
    else
        require 'rayvn/prompt' 'rayvn/central'
        confirm "Create new GitHub repo for project '${projectName}'?" yes no choiceIndex || bye
        if (( choiceIndex == 0 )); then
            if ! gh auth status --active &> /dev/null; then
                confirm "Need to authenticate. Do you have a GitHub account?" y n choiceIndex || bye
                if (( choiceIndex == 0 )); then
                    gh auth login || exit
                else
                    bye "Please go to https://github.com/ and create an account first."
                fi
            fi
            echo
            gh repo create "${projectName}" --add-readme --private --clone || fail
            cd "${projectRoot}" || fail
            repoUrl="${ git remote get-url origin; }"
            registerProjectOnRayvnCentral "${projectName}" || fail
            createdRepo=1
        else
            echo
            makeDir "${projectRoot}" > /dev/null
            cd "${projectRoot}" || fail
            git init --initial-branch=main || fail
        fi
    fi
    makeDir "${binDir}" > /dev/null
    makeDir "${libDir}" > /dev/null

    # Ok, directories are ready, copy and substitute files

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/example'"
    local libraryCall='myExampleLibraryFunction'
    local libraryName="example"
    local libraryNameInitialCap="Example"
    local projectNameClass="${projectName^}"

    copyFileAndSubstituteVars "${packageTemplate}" './rayvn.pkg' quotedName || fail
    copyFileAndSubstituteVars "${libraryTemplate}" './lib/example.sh' projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail
    copyFileAndSubstituteVars "${scriptTemplate}" "./bin/${projectName}" quotedName qualifiedName libraryCall || fail
    chmod +x "./bin/${projectName}" || fail
    copyFileAndSubstituteVars "${readmeTemplate}" './README.md' projectName || fail
    copyFileAndSubstituteVars "${flakeTemplate}" './flake.nix' projectName || fail
    makeDir './formula' > /dev/null
    copyFileAndSubstituteVars "${formulaTemplate}" "./formula/${projectName}.rb" projectName projectNameClass || fail

    # Add and commit

    git add --all
    git commit -m "initial commit"

    # Did we create the repo?

    if (( createdRepo )); then

        # Yes, so we push the changes

        git push -u origin main || fail
        echo "New project files pushed."
        echo
    else
        echo
        show bold "Once you create a repo on GitHub, use the following commands to push it:"
        echo
        echo "   cd ${projectRoot}"
        echo "   git remote add origin https://github.com/YOUR_GH_USER_NAME/${projectName}.git"
        echo "   git push -u origin main"
        echo
    fi

    show "Please update the" primary "projectDescription" "property in the" blue "rayvn.pkg" "file."
    remindIfNotInPath "${binDir}"
}

remindIfNotInPath() {
    local binDir="$1"
    if [[ ! ":${PATH}:" == *":${binDir}:"* ]]; then
        show "Remember to add" blue "${binDir}" "to your PATH."
    fi
}

newScript() {
    local projectRoot projectName
    local templateFile="${templateDir}/script-template.sh"
    getProjectRoot projectRoot projectName

    local binDir="${projectRoot}/bin"
    local scriptFile="${binDir}/${name}"
    ensureDir "${binDir}"
    assertFileDoesNotExist "${scriptFile}"

    local quotedName="'${projectName}'"
    local qualifiedName=
    local libraryCall='# ...'
    copyFileAndSubstituteVars "${templateFile}" "${scriptFile}" quotedName qualifiedName libraryCall || fail

    chmod +x "${scriptFile}" || fail
    git add "${scriptFile}" || fail

    show "Created" blue "bin/${name}"
    remindIfNotInPath "${binDir}"
}

newLibrary() {
    local projectRoot projectName
    local templateFile="${templateDir}/library-template.sh"
    getProjectRoot projectRoot projectName

    local libDir="${projectRoot}/lib"
    local libraryFile="${libDir}/${name}.sh"
    ensureDir "${libDir}"
    assertFileDoesNotExist "${libraryFile}"

    local quotedName="'${projectName}'"
    local qualifiedName="'${projectName}/${name}'"
    local libraryName="${name}"
    local libraryNameInitialCap="${name^}"

    copyFileAndSubstituteVars "${templateFile}" "${libraryFile}" projectName quotedName qualifiedName libraryName libraryNameInitialCap || fail

    git add "${libraryFile}" || fail

    show "Created" blue "lib/${name}.sh"
}

newTest() {
    local projectRoot projectName
    local templateFile="${templateDir}/test-template.sh"
    getProjectRoot projectRoot projectName

    local testDir="${projectRoot}/test"
    local testFileName="test-${name}.sh"
    local testFile="${testDir}/${testFileName}"
    ensureDir "${testDir}"
    assertFileDoesNotExist "${testFile}"

    cp "${templateFile}" "${testFile}"|| fail
    chmod +x "${testFile}" || fail
    git add "${testFile}" || fail

    show "Created" blue "test/${testFileName}"
}

getProjectRoot() {
    local -n projectRootRef="$1"
    local -n projectNameRef="$2"

    [[ -n ${gitRoot} ]] || bye "${PWD} is not within a project/git repo"
    local _projectRoot="${gitRoot}"
    local packageFile="${_projectRoot}/rayvn.pkg"
    [[ -f "${packageFile}" ]] || bye "${_projectRoot} does not appear to be a rayvn project: no rayvn.pkg file"
    local _projectName; _projectName="${ baseName ${_projectRoot}; }"
    projectRootRef="${_projectRoot}"
    projectNameRef="${_projectName}"
}

copyFileAndSubstituteVars() {
    local inputFile=$1
    local outputFile=$2
    local varList=("${@:3}")

    { [[ -z ${inputFile} || -z ${outputFile} ]] || (( ${#varList[@]} == 0 )); } &&
        fail "Usage: substituteVars inputFile outputFile <varName> [<varName> ...]"

    local sedExprs=()
    for varName in "${varList[@]}"; do
        local value=${!varName}
        # Escape for sed: backslash, ampersand, and delimiter /
        value=${value//\\/\\\\}
        value=${value//&/\\&}
        value=${value//\//\\/}
        sedExprs+=("-e" "s/\${${varName}}/${value}/g")
    done

    gsed "${sedExprs[@]}" "${inputFile}" > "${outputFile}"
}

ARGS_PARSER_BEGIN="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 🚫 BEGIN generated code: DO NOT EDIT 🚫 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

parseCommand() {
    _opts=()
    _args=()
    parseCommonOptions rayvn "$@"; shift $?
    case "$1 ${2:-}" in
        "docs audit") shift 2; parseDocsAuditArgs "$@"; (( _opts['help'] )) && docsAuditCmdUsage || docsAuditCmd ;;
        "docs update") shift 2; parseDocsUpdateArgs "$@"; (( _opts['help'] )) && docsUpdateCmdUsage || docsUpdateCmd ;;
        *)
            case "$1" in
                args) shift; parseArgsArgs "$@"; (( _opts['help'] )) && argsCmdUsage || argsCmd ;;
                build) shift; parseBuildArgs "$@"; (( _opts['help'] )) && buildCmdUsage || buildCmd ;;
                collisions) shift; parseCollisionsArgs "$@"; (( _opts['help'] )) && collisionsCmdUsage || collisionsCmd ;;
                deps | dependencies) shift; parseDependenciesArgs "$@"; (( _opts['help'] )) && dependenciesCmdUsage || dependenciesCmd ;;
                functions) shift; parseFunctionsArgs "$@"; (( _opts['help'] )) && functionsCmdUsage || functionsCmd ;;
                index) shift; parseIndexArgs "$@"; (( _opts['help'] )) && indexCmdUsage || indexCmd ;;
                libraries) shift; parseLibrariesArgs "$@"; (( _opts['help'] )) && librariesCmdUsage || librariesCmd ;;
                lint) shift; parseLintArgs "$@"; (( _opts['help'] )) && lintCmdUsage || lintCmd ;;
                new | create) shift; parseNewArgs "$@"; (( _opts['help'] )) && newCmdUsage || newCmd ;;
                pages) shift; parsePagesArgs "$@"; (( _opts['help'] )) && pagesCmdUsage || pagesCmd ;;
                projects) shift; parseProjectsArgs "$@"; (( _opts['help'] )) && projectsCmdUsage || projectsCmd ;;
                register) shift; parseRegisterArgs "$@"; (( _opts['help'] )) && registerCmdUsage || registerCmd ;;
                release) shift; parseReleaseArgs "$@"; (( _opts['help'] )) && releaseCmdUsage || releaseCmd ;;
                test) shift; parseTestArgs "$@"; (( _opts['help'] )) && testCmdUsage || testCmd ;;
                theme) shift; parseThemeArgs "$@"; (( _opts['help'] )) && themeCmdUsage || themeCmd ;;
                docs)
                    case "${2:-}" in
                        -h | --help) docsCmdUsage ;;
                        *) docsCmdUsage "docs requires a subcommand: audit, update" ;;
                    esac
                    ;;
                *) usage "unknown command: $1" ;;
            esac
            ;;
    esac
}

docsCmdUsage() {
    echo
    show "Usage:" bold blue "rayvn docs" "SUBCOMMAND [OPTIONS]"
    echo
    echo "Subcommands:"
    echo
    option "audit" "Report missing/stale ◇ doc comments." 12
    option "update" "Generate or fix ◇ doc comments via Claude API." 12
    echo
    echo "Use 'rayvn docs SUBCOMMAND --help' for details on a specific subcommand."
    bye "$@"
}

parseArgsArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=argsCmdUsage
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --check) _opts+=(['check']="1"); shift ;;
            --check=*) fail "--check does not accept a value" ;;
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --) shift
                while (( $# > 0 )); do
                    (( _argIndex == 0 )) && assertExecutable "$1" || unknownArg "$1"
                    _args+=("$1"); (( _argIndex++ )); shift
                done ;;
            *) (( _argIndex == 0 )) && assertExecutable "$1" || unknownArg "$1"; _args+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _opts['help'] || _argIndex >= 1 )) || { local -a _missingArgs=("SCRIPT"); _missingArgs=("${_missingArgs[@]:${_argIndex}}"); (( ${#_missingArgs[@]} == 1 )) && fail "missing required argument: ${_missingArgs[0]}" || fail "missing required arguments: ${_missingArgs[*]}"; }
    declare -g _failHandler="${_prevFailHandler}"
}

argsCmdUsage() {
    echo
    show bold "Regenerate the parser block in SCRIPT from its spec, or with --check report whether the committed"
    show bold "block is stale without modifying the file."
    echo
    show "Usage:" bold blue "rayvn args" "SCRIPT [--check]"
    echo
    option "SCRIPT" "Path to the script to update, or a bare executable name (e.g. 'rayvn'); must contain" 16
    option "" "a rayvn:args or rayvn:cli annotation." 16
    option "--check" "Report drift without updating the file." 16
    option "--help, -h" "Print this help message." 16
    echo
    echo "Annotation formats:"
    echo
    echo "    # rayvn:args specVar [funcName]   → parse\${funcName^}Args()"
    echo "    # rayvn:cli  specVar              → parseCommand() + per-command parsers"
    echo
    echo "The spec variable must be defined at global scope (not inside a function)."
    declare -F argsCmdUsageExtra > /dev/null && argsCmdUsageExtra
    bye "$@"
}

