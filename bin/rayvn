parseNewArgs() {
    local _prevFailHandler="${_failHandler}"
    declare -g _failHandler=newCmdUsage
    local _argIndex=0
    while (( $# > 0 )); do
        case "$1" in
            --help | -h) _opts+=(['help']="1"); shift ;;
            --help=*) fail "--help does not accept a value" ;;
            --local) _opts+=(['local']="1"); shift ;;
            --local=*) fail "--local does not accept a value" ;;
            --) shift
                while (( $# > 0 )); do
                    (( _argIndex < 2 )) || unknownArg "$1"
                    (( _argIndex == 0 )) && { [[ "|project|script|library|test|" == *"|$1|"* ]] || fail "$1 must be one of: project|script|library|test"; }
                    _args+=("$1"); (( _argIndex++ )); shift
                done ;;
            *)
                (( _argIndex < 2 )) || unknownArg "$1"
                (( _argIndex == 0 )) && { [[ "|project|script|library|test|" == *"|$1|"* ]] || fail "$1 must be one of: project|script|library|test"; }
                _args+=("$1"); (( _argIndex++ )); shift ;;
        esac
    done
    (( _opts['help'] || _argIndex >= 2 )) || { local -a _missingArgs=("TYPE" "NAME"); _missingArgs=("${_missingArgs[@]:${_argIndex}}"); (( ${#_missingArgs[@]} == 1 )) && fail "missing required argument: ${_missingArgs[0]}" || fail "missing required arguments: ${_missingArgs[*]}"; }
    declare -g _failHandler="${_prevFailHandler}"
}

