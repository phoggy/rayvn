#!/usr/bin/env rayvn-bash
# shellcheck disable=SC2155

# Manage RAM-backed temp storage for rayvn.
#
# On Linux, /dev/shm (tmpfs) is used automatically — nothing to configure.
# On macOS 10.15+, an optional tmpfs mount can be set up for improved security.
# Older macOS falls back to a mode-600 temp file (secure but disk-backed).

usage() {
    echo
    show bold "Manage RAM-backed temp storage for rayvn."
    echo
    show "Usage:" bold "${scriptName}" "[COMMAND]"
    echo
    echo "Commands"
    echo
    echo "    status       Show current temp storage strategy (default)."
    echo "    install      Install LaunchDaemon to mount tmpfs at boot (macOS, requires sudo)."
    echo "    uninstall    Remove the LaunchDaemon and unmount tmpfs (macOS, requires sudo)."
    echo
    echo "Options"
    echo
    showCommonOptions 17 false
    bye "$@"
}

main() {
    init "$@"
    ${command}
}

# shellcheck disable=SC2155
init() {
    declare -g command='status'

    while (( $# )); do
        case "$1" in
            status | install | uninstall) command="$1" ;;
            -h | --help) usage ;;
            -v) projectVersion 'rayvn'; exit 0 ;;
            --version) projectVersion 'rayvn' true; exit 0 ;;
            --debug*) setDebug "$@"; shift $? ;;
            *) usage "Unknown option: $1" ;;
        esac
        shift
    done
}

status() {
    echo
    show bold "rayvn temp storage"
    echo
    case "${_secureTempStrategy}" in
        linux_shm)
            show success "Active:" "Linux /dev/shm (RAM-backed tmpfs)"
            ;;
        macos_tmpfs)
            show success "Active:" "macOS tmpfs at ${_secureTempBase}"
            ;;
        secure_temp)
            show warning "Active:" "disk-backed temp (mode 600, secure but not RAM-backed)"
            echo
            if (( onMacOS )); then
                local tmpPath="${RAYVN_TMP_PATH:-/private/var/rayvn-tmp}"
                local tmpSize="${RAYVN_TMP_SIZE:-1g}"
                if _isMacOSSupportedVersion; then
                    show "macOS 10.15+ detected — RAM-backed tmpfs is available and is even more secure."
                    echo
                    show "Run" bold "rayvn-tmp install" "to set up automatic mounting at boot. It can be mounted now,"
                    show "but note that this will" italic bold "not survive reboot."
                    echo
                    local answerIndex
                    confirm "Would you like to mount it now?" yes no answerIndex || bye
                    if (( answerIndex == 0 )); then
                        show "OK. You will be asked to enter your login password" muted "(sudo required)"
                        echo
                        sudo mkdir -p "${tmpPath}" || fail
                        sudo /sbin/mount_tmpfs -s "${tmpSize}" "${tmpPath}" || fail
                        sudo chmod 1777 "${tmpPath}" || fail
                        mkdir -p "${tmpPath}/${UID}" && chmod 700 "${tmpPath}/${UID}" || fail
                        show success "Done. tmpfs at" blue "${tmpPath}" muted "(${tmpSize} capacity)"
                    else
                        echo
                        show "Ok. If you would like to do it yourself, run the following commands:"
                        echo
                        echo "    sudo mkdir -p ${tmpPath}"
                        echo "    sudo /sbin/mount_tmpfs -o nobrowse -s ${tmpSize} ${tmpPath}"
                        echo "    sudo chmod 1777 ${tmpPath}"
                        echo "    mkdir -p ${tmpPath}/\${UID} && chmod 700 ${tmpPath}/\${UID}"
                    fi
                else
                    show muted "RAM-backed tmpfs not available on this macOS version (requires 10.15+)."
                fi
            fi
            ;;
    esac
    echo
}

install() {
    (( onMacOS )) || fail "LaunchDaemon install is macOS-only"
    _isMacOSSupportedVersion || fail "macOS 10.15+ required for tmpfs support"

    local realUid="${SUDO_UID:-${UID}}"
    local tmpPath="${RAYVN_TMP_PATH:-/private/var/rayvn-tmp}"
    local tmpSize="${RAYVN_TMP_SIZE:-1g}"
    local userDir="${tmpPath}/${realUid}"
    local plistDest='/Library/LaunchDaemons/org.rayvn.tmp.plist'

    echo
    if [[ ! -f "${plistDest}" ]]; then
        local plistFile; plistFile="${ makeTempFile 'rayvn-tmp-plist-XXXXXX'; }"

        # lint-skip-start
        cat > "${plistFile}" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.rayvn.tmp</string>
    <key>RunAtLoad</key>
    <true/>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>mkdir -p ${tmpPath} &amp;&amp; /sbin/mount_tmpfs -o nobrowse -s ${tmpSize} ${tmpPath} &amp;&amp; chmod 1777 ${tmpPath}</string>
    </array>
</dict>
</plist>
EOF
        # lint-skip-end

        show "Installing LaunchDaemon to" bold "${plistDest}"
        show "You will be asked to enter your login password" muted "(sudo required)"
        echo
        sudo cp "${plistFile}" "${plistDest}" || fail "failed to install plist"
        sudo launchctl load "${plistDest}" || fail "failed to load LaunchDaemon"
        show success "Installed." "tmpfs will be mounted at" bold "${tmpPath}" "on every boot" muted "(${tmpSize} capacity)"
    else
        show muted "LaunchDaemon already installed."
    fi

    if ! mount | grep -q " on ${tmpPath} (tmpfs"; then
        show "Mounting now..."
        sudo mkdir -p "${tmpPath}" && sudo /sbin/mount_tmpfs -s "${tmpSize}" "${tmpPath}" && sudo chmod 1777 "${tmpPath}" || fail "failed to mount tmpfs"
        show success "Mounted at" bold "${tmpPath}"
    fi

    mkdir -p "${userDir}" && chown "${realUid}" "${userDir}" && chmod 700 "${userDir}" || fail "failed to create user temp dir"
    show success "User temp dir ready:" bold "${userDir}"
    echo
}

uninstall() {
    (( onMacOS )) || fail "LaunchDaemon uninstall is macOS-only"

    local tmpPath="${RAYVN_TMP_PATH:-/private/var/rayvn-tmp}"
    local plistDest='/Library/LaunchDaemons/org.rayvn.tmp.plist'

    echo
    if [[ -f "${plistDest}" ]]; then
        show "Removing LaunchDaemon" bold "${plistDest}"
        show muted "(sudo required)"
        echo
        sudo launchctl unload "${plistDest}" 2> /dev/null || true
        sudo rm "${plistDest}" || fail "failed to remove plist"
        show success "LaunchDaemon removed."
    else
        show muted "LaunchDaemon not installed."
    fi

    if mount | grep -q " on ${tmpPath} (tmpfs"; then
        show "Unmounting ${tmpPath}..."
        sudo umount "${tmpPath}" || fail "failed to unmount"
        show success "Unmounted."
    fi
    echo
}

_isMacOSSupportedVersion() {
    local major minor
    IFS='.' read -r major minor _ < <(sw_vers -productVersion)
    (( major > 10 || (major == 10 && minor >= 15) ))
}

source rayvn.up 'rayvn/core' 'rayvn/prompt' || exit
main "$@"
